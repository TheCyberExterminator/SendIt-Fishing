<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5.0" />
<title>SendIt Fishing — Should I send it today?</title>
<meta name="description" content="SendIt Fishing AU — the free Aussie fishing forecast that answers one question: should I send it today? Live tides, weather, wind, moon, solunar bite windows, species advice, weekend planner and a catch log. No signup, works offline." />
<meta name="theme-color" content="#06141f" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="apple-mobile-web-app-title" content="SendIt" />
<link rel="manifest" href="manifest.webmanifest" />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%2306141f'/%3E%3Cpath d='M14 32c9-12 28-12 37 0-9 12-28 12-37 0z' fill='none' stroke='%2333e1c0' stroke-width='3'/%3E%3Ccircle cx='40' cy='29' r='2.4' fill='%2333e1c0'/%3E%3Cpath d='M51 32l8-6v12z' fill='%2333e1c0'/%3E%3C/svg%3E" />
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'%3E%3Crect width='192' height='192' rx='42' fill='%2306141f'/%3E%3Cpath d='M40 96c26-34 86-34 112 0-26 34-86 34-112 0z' fill='none' stroke='%2333e1c0' stroke-width='9'/%3E%3Ccircle cx='120' cy='88' r='7' fill='%2333e1c0'/%3E%3Cpath d='M150 96l24-17v34z' fill='%2333e1c0'/%3E%3C/svg%3E" />
<style>
/* ---- DARK (default) ---- */
:root{
  --bg:#06141f; --bg2:#0a1c2b; --panel:#0e2435; --panel2:#123048; --line:#1c3a52;
  --text:#e8f1f7; --muted:#8aa4b8; --faint:#5d788f;
  --aqua:#33e1c0; --aqua2:#2bd4d4; --blue:#4aa8ff; --sand:#f4c66a;
  --good:#33e1c0; --warn:#f4b740; --bad:#ff6b6b; --shadow:rgba(0,0,0,.45);
  --grad:radial-gradient(1200px 600px at 50% -10%, #0c2334 0%, var(--bg) 60%);
  --r:18px; --r2:14px;
}
/* ---- LIGHT ---- */
html.light{
  --bg:#eef4f8; --bg2:#ffffff; --panel:#ffffff; --panel2:#f1f6fa; --line:#d8e3ec;
  --text:#0e2233; --muted:#5a7488; --faint:#90a6b6;
  --aqua:#0bb39a; --aqua2:#0a93b8; --blue:#2f7fd6; --sand:#cf8a1f;
  --good:#0bb39a; --warn:#c98a0c; --bad:#e0453f; --shadow:rgba(15,40,60,.12);
  --grad:radial-gradient(1200px 600px at 50% -10%, #dbe9f2 0%, var(--bg) 60%);
}
/* ---- FUN (playful tropical/sunset) ---- */
html.fun{
  --bg:#1a0f2e; --bg2:#241544; --panel:#2a1850; --panel2:#37205f; --line:#4a2d7a;
  --text:#fdf0ff; --muted:#c3a9e6; --faint:#9a7fc0;
  --aqua:#2bf0c4; --aqua2:#36d0ff; --blue:#7c6bff; --sand:#ffd23f;
  --good:#3ef0a0; --warn:#ffb13f; --bad:#ff5d8f; --shadow:rgba(40,0,60,.5);
  --grad:radial-gradient(900px 560px at 80% -8%, rgba(255,93,143,.20) 0%, transparent 55%),
         radial-gradient(900px 600px at 12% 12%, rgba(54,208,255,.16) 0%, transparent 52%),
         linear-gradient(180deg,#241544,#1a0f2e);
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{margin:0;background:var(--grad);background-attachment:fixed;
  color:var(--text);font-family:system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
  min-height:100%;line-height:1.45;-webkit-text-size-adjust:100%;
  transition:background-color .25s ease,color .25s ease}
.safe-top{padding-top:env(safe-area-inset-top)}
.wrap{max-width:560px;margin:0 auto;padding:0 14px 64px}
h1,h2,h3{margin:0;font-weight:700;letter-spacing:-.01em}
button{font:inherit;color:inherit;cursor:pointer;border:0;background:none}
input,select{font:inherit;color:inherit}
a{color:var(--aqua2)}
.muted{color:var(--muted)}
.faint{color:var(--faint)}
.card{background:linear-gradient(180deg,var(--panel),var(--bg2));border:1px solid var(--line);
  border-radius:var(--r);padding:16px;margin-top:14px;box-shadow:0 6px 18px var(--shadow)}
.card h2{font-size:15px;display:flex;align-items:center;gap:8px;margin-bottom:10px}
.row{display:flex;align-items:center;gap:10px}
.between{display:flex;align-items:center;justify-content:space-between;gap:10px}
.chip{display:inline-flex;align-items:center;gap:5px;background:var(--panel2);border:1px solid var(--line);
  border-radius:999px;padding:4px 10px;font-size:12px;white-space:nowrap}
.chip.good{color:var(--good);border-color:rgba(51,225,192,.4)}
.chip.warn{color:var(--warn);border-color:rgba(244,183,64,.4)}
.chip.bad{color:var(--bad);border-color:rgba(255,107,107,.4)}
.chip.blue{color:var(--blue);border-color:rgba(74,168,255,.4)}
.tap{transition:transform .08s ease}.tap:active{transform:scale(.96)}
.btn{background:var(--panel2);border:1px solid var(--line);border-radius:var(--r2);padding:10px 14px;
  font-size:13px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;gap:7px}
.btn.primary{background:linear-gradient(180deg,var(--aqua),#1bbfa3);color:#04201b;border-color:transparent}
.btn.full{width:100%}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
svg.ic{width:18px;height:18px;flex:0 0 auto;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
/* header */
header{position:sticky;top:0;z-index:50;background:rgba(6,20,31,.82);backdrop-filter:blur(12px);
  border-bottom:1px solid var(--line)}
.brand{font-size:16px;font-weight:800;letter-spacing:-.02em}
.brand b{color:var(--aqua)}
.searchbar{display:flex;align-items:center;gap:8px;background:var(--panel);border:1px solid var(--line);
  border-radius:var(--r2);padding:0 10px;height:42px;margin-top:10px}
.searchbar input{flex:1;background:none;border:0;outline:none;font-size:15px;min-width:0}
.iconbtn{width:42px;height:42px;border-radius:var(--r2);background:var(--panel);border:1px solid var(--line);
  display:grid;place-items:center;flex:0 0 auto;color:var(--aqua)}
#suggest{position:absolute;left:14px;right:14px;background:var(--panel);border:1px solid var(--line);
  border-radius:var(--r2);margin-top:6px;overflow:hidden;z-index:60;box-shadow:0 12px 30px var(--shadow)}
#suggest button{display:flex;width:100%;text-align:left;gap:8px;padding:11px 12px;align-items:center;
  border-bottom:1px solid var(--line);font-size:14px}
#suggest button:last-child{border-bottom:0}
#suggest button:active{background:var(--panel2)}
/* score */
.scoreCard{display:flex;gap:16px;align-items:center}
.ring{position:relative;width:118px;height:118px;flex:0 0 auto}
.ring svg{transform:rotate(-90deg)}
.ring .val{position:absolute;inset:0;display:grid;place-items:center;text-align:center}
.ring .num{font-size:34px;font-weight:800;line-height:1}
.ring .lbl{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-top:3px}
.word{font-size:20px;font-weight:800}
.sub{font-size:13px;color:var(--muted);margin-top:2px}
.factors{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.bestwin{margin-top:10px;font-size:13px;color:var(--aqua2);font-weight:600}
/* metric tiles */
.tiles{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.tile{background:var(--panel2);border:1px solid var(--line);border-radius:var(--r2);padding:12px}
.tile .k{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.tile .v{font-size:22px;font-weight:800;margin-top:3px}
.tile .v small{font-size:12px;font-weight:600;color:var(--muted)}
.tile .x{font-size:12px;color:var(--muted);margin-top:2px}
/* lists */
.list>div{padding:9px 0;border-bottom:1px solid var(--line)}
.list>div:last-child{border-bottom:0}
.tideRow{display:flex;align-items:center;gap:10px}
.tideRow .t{flex:1;font-weight:700;color:var(--aqua2)}
.tideRow .h{font-variant-numeric:tabular-nums;color:var(--muted)}
.daycard{background:var(--panel2);border:1px solid var(--line);border-radius:var(--r2);padding:10px 12px;margin-bottom:8px}
.daycard .hd{display:flex;justify-content:space-between;font-size:13px;font-weight:700;margin-bottom:4px}
/* species chips */
.specbar{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;margin:-2px -2px 10px}
.specbar::-webkit-scrollbar{display:none}
.specbar{scrollbar-width:none}
.specbar button{flex:0 0 auto;padding:7px 12px;border-radius:999px;background:var(--panel2);
  border:1px solid var(--line);font-size:13px;font-weight:600}
.specbar button.on{background:var(--aqua);color:#04201b;border-color:transparent}
.prob{height:8px;border-radius:999px;background:var(--line);overflow:hidden;margin-top:6px}
.prob>i{display:block;height:100%;border-radius:999px}
/* safety */
.safety{border-radius:var(--r);padding:14px;margin-top:14px;border:1px solid var(--line)}
.safety.danger{border-color:rgba(255,107,107,.5);background:rgba(255,107,107,.08)}
.safety.warn{border-color:rgba(244,183,64,.5);background:rgba(244,183,64,.08)}
.safety ul{margin:8px 0 0;padding-left:0;list-style:none;font-size:13px}
.safety li{display:flex;gap:8px;margin-top:6px}
.safety li i{width:7px;height:7px;border-radius:50%;margin-top:6px;flex:0 0 auto}
/* weekend planner */
.plan{display:flex;gap:8px;overflow-x:auto;padding-bottom:4px}
.plan::-webkit-scrollbar{display:none}.plan{scrollbar-width:none}
.planday{flex:0 0 88px;background:var(--panel2);border:1px solid var(--line);border-radius:var(--r2);
  padding:10px;text-align:center}
.planday.best{border-color:var(--aqua);box-shadow:0 0 0 1px var(--aqua) inset}
.planday .d{font-size:12px;color:var(--muted)}
.planday .em{font-size:22px;margin:4px 0}
.planday .s{font-weight:800;font-size:18px}
/* chips row scroller */
.scroller{display:flex;gap:8px;overflow-x:auto;padding-bottom:2px}
.scroller::-webkit-scrollbar{display:none}.scroller{scrollbar-width:none}
/* sheet */
.sheetWrap{position:fixed;inset:0;z-index:200;display:none}
.sheetWrap.open{display:block}
.sheetBg{position:absolute;inset:0;background:rgba(0,0,0,.6)}
.sheet{position:absolute;left:0;right:0;bottom:0;max-width:560px;margin:0 auto;background:var(--panel);
  border:1px solid var(--line);border-top-left-radius:22px;border-top-right-radius:22px;
  padding:16px 16px calc(env(safe-area-inset-bottom) + 18px);max-height:88vh;overflow:auto}
.sheet label{font-size:12px;color:var(--muted);display:block;margin:10px 0 4px}
.sheet input,.sheet select,.sheet textarea{width:100%;background:var(--panel2);border:1px solid var(--line);
  border-radius:12px;padding:11px;outline:none}
/* toast */
#toast{position:fixed;left:50%;transform:translateX(-50%);bottom:26px;z-index:300;background:var(--panel2);
  border:1px solid var(--line);border-radius:12px;padding:10px 16px;font-size:14px;display:none;
  box-shadow:0 10px 30px var(--shadow)}
/* segmented controls (settings) */
.segrow{display:flex;gap:6px;background:var(--panel2);border:1px solid var(--line);border-radius:12px;padding:4px}
.seg{flex:1;text-align:center;padding:9px 6px;border-radius:9px;font-size:13px;font-weight:700;color:var(--muted)}
.seg.on{background:var(--aqua);color:#04201b}
.pingrow{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid var(--line);font-size:13px}
/* source badge */
.src{font-size:11px;padding:3px 8px;border-radius:999px;border:1px solid var(--line)}
.src.live{color:var(--good);border-color:rgba(51,225,192,.4)}
.src.cache{color:var(--blue);border-color:rgba(74,168,255,.4)}
.src.engine{color:var(--warn);border-color:rgba(244,183,64,.4)}
.src.est{color:var(--warn);border-color:rgba(244,183,64,.4)}
.src.off{color:var(--bad);border-color:rgba(255,107,107,.4)}
/* footer */
footer{text-align:center;color:var(--muted);font-size:12px;padding:26px 0 6px}
footer .bn{color:var(--aqua);font-weight:800;font-size:14px}
footer .me{color:var(--text);font-weight:600;margin-top:6px}
/* debug */
#debug{font-family:ui-monospace,Menlo,Consolas,monospace;font-size:11px}
#debug .kv{display:flex;justify-content:space-between;gap:10px;padding:3px 0;border-bottom:1px solid var(--line)}
#debug .kv span:last-child{text-align:right;color:var(--aqua2);word-break:break-all}
.skeleton{color:var(--muted);font-size:13px}
canvas{width:100%;display:block}
.hidden{display:none !important}
@media (prefers-reduced-motion: reduce){*{animation:none!important;transition:none!important}}
:focus-visible{outline:2px solid var(--aqua);outline-offset:2px;border-radius:8px}
</style>
<script>/* apply saved theme before paint to avoid a flash */(function(){try{var t=JSON.parse(localStorage.getItem('sendit_theme'));if(t!=='light'&&t!=='fun')t='';document.documentElement.className=t;var c=t==='light'?'#eef4f8':t==='fun'?'#1a0f2e':'#06141f';var m=document.querySelector('meta[name="theme-color"]');if(m)m.setAttribute('content',c);}catch(e){}})();</script>
</head>
<body>
<header class="safe-top">
  <div class="wrap" style="padding-bottom:12px">
    <div class="between" style="padding-top:12px">
      <div class="row" style="gap:10px;min-width:0">
        <div class="iconbtn" aria-hidden="true">
          <svg class="ic" viewBox="0 0 24 24"><path d="M4 12c5-7 16-7 21 0-5 7-16 7-21 0z"/><circle cx="16" cy="10.5" r="1" fill="currentColor" stroke="none"/></svg>
        </div>
        <div style="min-width:0">
          <div class="brand">Send<b>It</b> <span class="muted" style="font-weight:600;font-size:12px">Fishing</span></div>
          <button id="locBtn" class="row" style="gap:5px;font-size:12px" aria-label="Current location">
            <svg class="ic" style="width:13px;height:13px;color:var(--aqua)" viewBox="0 0 24 24"><path d="M12 21s-7-5.5-7-11a7 7 0 0114 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>
            <span id="locName" class="muted">Locating…</span>
          </button>
        </div>
      </div>
      <div class="row" style="gap:8px">
        <button id="gpsBtn" class="iconbtn tap" title="Use my location" aria-label="Use my location">
          <svg class="ic" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/><circle cx="12" cy="12" r="8"/></svg>
        </button>
        <button id="favBtn" class="iconbtn tap" title="Save spot" aria-label="Save this spot">
          <svg id="favIc" class="ic" viewBox="0 0 24 24"><path d="M12 17.3l-6.2 3.7 1.6-7L2 9.2l7.1-.6L12 2l2.9 6.6 7.1.6-5.4 4.8 1.6 7z"/></svg>
        </button>
        <button id="setBtn" class="iconbtn tap" title="Settings" aria-label="Settings">
          <svg class="ic muted" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.6 1.6 0 00.3 1.8l.1.1a2 2 0 11-2.8 2.8l-.1-.1a1.6 1.6 0 00-2.7 1.1V21a2 2 0 11-4 0v-.1A1.6 1.6 0 005 19.4l-.1.1a2 2 0 11-2.8-2.8l.1-.1A1.6 1.6 0 003 14H3a2 2 0 110-4h.1A1.6 1.6 0 004.6 5l-.1-.1A2 2 0 117.3 2.1L7.4 2.2A1.6 1.6 0 0010 2.5V3a2 2 0 114 0v.1a1.6 1.6 0 002.7 1.1l.1-.1a2 2 0 112.8 2.8l-.1.1a1.6 1.6 0 00-.3 1.8z"/></svg>
        </button>
      </div>
    </div>
    <div style="position:relative">
      <div class="searchbar">
        <svg class="ic muted" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <input id="search" type="text" inputmode="search" autocomplete="off" placeholder="Search a town, beach or postcode…" aria-label="Search location" />
        <button id="searchClear" class="muted hidden" aria-label="Clear" style="font-size:20px;padding:0 4px">&times;</button>
      </div>
      <div id="suggest" class="hidden"></div>
    </div>
    <div id="favChips" class="scroller" style="margin-top:8px"></div>
  </div>
</header>

<main class="wrap" id="app">

  <!-- 2. SENDIT SCORE -->
  <section class="card" id="scoreCard">
    <div class="between" style="margin-bottom:12px">
      <div class="row" style="gap:8px"><span id="updated" class="muted" style="font-size:12px">Loading…</span></div>
      <button id="refreshBtn" class="chip blue tap"><svg class="ic" style="width:14px;height:14px" viewBox="0 0 24 24"><path d="M3 12a9 9 0 019-9 9 9 0 016.7 3M21 12a9 9 0 01-9 9 9 9 0 01-6.7-3"/><path d="M18 3v4h-4M6 21v-4h4"/></svg>Refresh</button>
    </div>
    <div class="scoreCard">
      <div class="ring">
        <svg viewBox="0 0 120 120" width="118" height="118">
          <circle cx="60" cy="60" r="52" fill="none" stroke="var(--line)" stroke-width="12"/>
          <circle id="ringArc" cx="60" cy="60" r="52" fill="none" stroke="var(--aqua)" stroke-width="12" stroke-linecap="round" stroke-dasharray="327" stroke-dashoffset="327"/>
        </svg>
        <div class="val"><div><div id="scoreNum" class="num">–</div><div class="lbl">SendIt</div></div></div>
      </div>
      <div style="min-width:0;flex:1">
        <div id="scoreWord" class="word">Reading conditions…</div>
        <div id="scoreSub" class="sub">Pulling live marine data</div>
        <div id="confBadge"></div>
        <div id="bestWindow" class="bestwin"></div>
      </div>
    </div>
    <div id="dataSrc" class="scroller" style="margin-top:12px"></div>
  </section>

  <!-- 3. BITE WINDOW TIMELINE -->
  <section class="card">
    <div class="between"><h2><svg class="ic" style="color:var(--aqua)" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>Bite Windows</h2>
      <div class="scroller" id="biteTabs" style="gap:6px"></div>
    </div>
    <div id="biteList" class="list"></div>
  </section>

  <!-- 4. WHY THIS SCORE -->
  <section class="card">
    <h2><svg class="ic" style="color:var(--aqua2)" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 16v-4M12 8h.01"/></svg>Why this score?</h2>
    <div id="whyList"></div>
  </section>

  <!-- 5. TIDES -->
  <section class="card">
    <div class="between"><h2><svg class="ic" style="color:var(--aqua2)" viewBox="0 0 24 24"><path d="M2 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/><path d="M2 17c2-3 4-3 6 0s4 3 6 0 4-3 6 0"/></svg>Tides</h2>
      <div class="row" style="gap:6px"><span id="tideSrc" class="src">—</span></div>
    </div>
    <div class="grid2" id="tideNowNext" style="margin-bottom:10px"></div>
    <canvas id="tideChart" height="130"></canvas>
    <div class="scroller" id="tideRange" style="gap:6px;margin:8px 0"></div>
    <div id="tideTable"></div>
    <div id="tideNote" class="faint" style="font-size:11px;margin-top:8px"></div>
  </section>

  <!-- 6. WEATHER + WIND -->
  <section class="card">
    <h2><svg class="ic" style="color:var(--blue)" viewBox="0 0 24 24"><path d="M3 15a4 4 0 014-4 5 5 0 019.6-1.5A3.5 3.5 0 1118 17H7a4 4 0 01-4-2z"/></svg>Weather &amp; Wind</h2>
    <div class="tiles" id="wxTiles"></div>
    <div class="grid3" id="wxExtra" style="margin-top:10px"></div>
  </section>

  <!-- 7. SPECIES + ADVICE -->
  <section class="card">
    <h2><svg class="ic" style="color:var(--aqua)" viewBox="0 0 24 24"><path d="M4 12c4-6 12-6 16 0-4 6-12 6-16 0z"/><circle cx="15" cy="11" r="1" fill="currentColor" stroke="none"/></svg>Species &amp; Advice</h2>
    <div class="specbar" id="specBar"></div>
    <div id="advice"></div>
  </section>

  <!-- 8. WEEKEND SENDIT PLANNER -->
  <section class="card">
    <div class="between"><h2><svg class="ic" style="color:var(--sand)" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>Weekend SendIt Planner</h2></div>
    <div id="bestSession" class="muted" style="font-size:13px;margin-bottom:10px"></div>
    <div class="plan" id="planRow"></div>
  </section>

  <!-- 9. FAVOURITES + RECENT -->
  <section class="card">
    <h2><svg class="ic" style="color:var(--sand)" viewBox="0 0 24 24"><path d="M12 17.3l-6.2 3.7 1.6-7L2 9.2l7.1-.6L12 2l2.9 6.6 7.1.6-5.4 4.8 1.6 7z"/></svg>Saved &amp; Recent</h2>
    <div id="savedBox"></div>
    <div class="muted" style="font-size:12px;margin:12px 0 6px">Recent searches</div>
    <div id="recentBox" class="scroller" style="gap:6px;flex-wrap:wrap"></div>
  </section>

  <!-- 10. CATCH LOG -->
  <section class="card">
    <div class="between"><h2><svg class="ic" style="color:var(--aqua)" viewBox="0 0 24 24"><path d="M4 4h16v16H4z"/><path d="M8 9h8M8 13h6"/></svg>Catch Log</h2>
      <button id="addCatch" class="chip good tap">+ Log a catch</button>
    </div>
    <div id="logStats" class="grid3" style="margin:4px 0 10px"></div>
    <div id="logList"></div>
  </section>

  <footer>
    <div class="bn">SendIt Fishing 🎣</div>
    <div>Should I send it today?</div>
    <div class="me">Made by Shadi Soltan</div>
    <div>Security Operations</div>
    <div class="faint" style="margin-top:8px;font-size:11px">Tides are predictions — check the Bureau of Meteorology before any low-tide rock or breakwall session. Wear a PFD. Never turn your back on the sea.</div>
  </footer>
</main>

<div class="sheetWrap" id="sheetWrap"><div class="sheetBg" id="sheetBg"></div><div class="sheet" id="sheet"></div></div>
<div id="toast"></div>

<script>
'use strict';
/* =====================================================================
   SendIt Fishing AU — single-file, modular, no external dependencies.
   Modules: AppState, Util, MoonService, SolunarService, TideService,
   WeatherService, GeocodingService, LocationService, ScoreEngine,
   SpeciesEngine, AdviceEngine, CacheService, FavoritesService,
   CatchLogService, UIService, DebugService, ServiceWorker.
   All data sources are free, no-key, browser-safe. Live first, honest
   fallbacks, per-location cache, debug behind ?debug=true.
   ===================================================================== */

/* ---------------- Util ---------------- */
const Util = (() => {
  const $ = (s, r = document) => r.querySelector(s);
  const $$ = (s, r = document) => [...r.querySelectorAll(s)];
  const clamp = (v, a, b) => Math.max(a, Math.min(b, v));
  const num = (v, d) => (typeof v === 'number' && isFinite(v)) ? v : d;
  const round = (v, d = 0) => { const p = 10 ** d; return Math.round(v * p) / p; };
  const esc = s => String(s == null ? '' : s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  const fmtTime = d => new Date(d).toLocaleTimeString('en-AU', { hour: 'numeric', minute: '2-digit' });
  const compass = deg => ['N', 'NNE', 'NE', 'ENE', 'E', 'ESE', 'SE', 'SSE', 'S', 'SSW', 'SW', 'WSW', 'W', 'WNW', 'NW', 'NNW'][Math.round(((deg % 360) / 22.5)) % 16];
  const ago = ts => { const s = (Date.now() - ts) / 1000; if (s < 60) return 'just now'; if (s < 3600) return Math.floor(s / 60) + 'm ago'; if (s < 86400) return Math.floor(s / 3600) + 'h ago'; return Math.floor(s / 86400) + 'd ago'; };
  function toast(m, ms = 2200) { const t = $('#toast'); t.textContent = m; t.style.display = 'block'; clearTimeout(t._t); t._t = setTimeout(() => t.style.display = 'none', ms); }
  return { $, $$, clamp, num, round, esc, fmtTime, compass, ago, toast };
})();
const { $, $$ } = Util;

/* ---------------- AppState ---------------- */
const AppState = {
  loc: null, data: null, loadSeq: 0, species: 'auto', biteTab: 0,
  units: 'kmh', debug: /[?&]debug=true/.test(location.search),
  online: navigator.onLine,
};

/* ---------------- DebugService ---------------- */
const DebugService = (() => {
  const d = { swVersion: 'sendit-v2-3', attempts: {}, };
  const log = (...a) => { if (AppState.debug) console.log('[SendIt]', ...a); };
  const group = (n) => { if (AppState.debug) console.group(n); };
  const end = () => { if (AppState.debug) console.groupEnd(); };
  function record(key, info) { d.attempts[key] = Object.assign({}, d.attempts[key], info); }
  return { d, log, group, end, record };
})();

/* ---------------- CacheService (per-location keys) ---------------- */
const CacheService = (() => {
  const PFX = 'sendit_';
  const safe = { get(k, def) { try { const v = localStorage.getItem(PFX + k); return v == null ? def : JSON.parse(v); } catch (_) { return def; } }, set(k, v) { try { localStorage.setItem(PFX + k, JSON.stringify(v)); } catch (_) { } }, del(k) { try { localStorage.removeItem(PFX + k); } catch (_) { } } };
  const key = (kind, lat, lon) => kind + '_' + Util.round(lat, 2) + '_' + Util.round(lon, 2);
  return {
    get: safe.get, set: safe.set, del: safe.del, key,
    getCond(lat, lon) { return safe.get(key('cond', lat, lon), null); },
    setCond(lat, lon, d) { safe.set(key('cond', lat, lon), d); },
    getTide(lat, lon) { const c = safe.get(key('tide', lat, lon), null); return (c && c.extrema && (Date.now() - c.at) < 5 * 86400000) ? c : null; },
    setTide(lat, lon, extrema, source) { safe.set(key('tide', lat, lon), { extrema, source, at: Date.now() }); },
    getHarm(lat, lon) { const c = safe.get(key('harm', lat, lon), null); return (c && c.fit && (Date.now() - c.at) < 45 * 86400000) ? c : null; },
    setHarm(lat, lon, fit) { safe.set(key('harm', lat, lon), { fit, at: Date.now() }); },
    lastKnownCond() { let best = null; try { for (let i = 0; i < localStorage.length; i++) { const k = localStorage.key(i); if (k && k.indexOf(PFX + 'cond_') === 0) { const v = safe.get(k.slice(PFX.length), null); if (v && v.fetchedAt && (!best || v.fetchedAt > best.fetchedAt)) best = v; } } } catch (_) { } return best; }
  };
})();

/* ---------------- ThemeService (dark / light / fun) ---------------- */
const ThemeService = (() => {
  const THEMES = ['dark', 'light', 'fun'];
  const get = () => { const t = CacheService.get('theme', 'dark'); return THEMES.includes(t) ? t : 'dark'; };
  const metaColor = t => t === 'light' ? '#eef4f8' : t === 'fun' ? '#1a0f2e' : '#06141f';
  function apply(t) { document.documentElement.className = (t === 'dark' ? '' : t); const m = document.querySelector('meta[name="theme-color"]'); if (m) m.setAttribute('content', metaColor(t)); }
  function set(t) { if (!THEMES.includes(t)) t = 'dark'; CacheService.set('theme', t); apply(t); if (AppState.data) UIService.render(AppState.data, AppState.data.score.stale); }
  return { get, set, apply, THEMES };
})();

/* ---------------- DiagnosticsService (API connection ping) ---------------- */
const DiagnosticsService = (() => {
  async function one(name, url) {
    const t0 = Date.now();
    try {
      const ctrl = new AbortController(); const to = setTimeout(() => ctrl.abort(), 9000);
      const opts = { signal: ctrl.signal, cache: 'no-store' };
      if (url.indexOf('api.met.no') >= 0) opts.headers = { 'User-Agent': 'SendIt-Fishing/2.0 fishing-app' };
      const r = await fetch(url, opts); clearTimeout(to);
      return { name, ok: r.ok, code: r.status, ms: Date.now() - t0 };
    } catch (e) { return { name, ok: false, code: (e && e.name === 'AbortError') ? 'timeout' : 'blocked', ms: Date.now() - t0 }; }
  }
  function ping(lat, lon) {
    const checks = [
      ['Weather (Open-Meteo)', 'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon + '&current=temperature_2m&timezone=auto'],
      ['Tide/Marine (Open-Meteo)', 'https://marine-api.open-meteo.com/v1/marine?latitude=' + lat + '&longitude=' + lon + '&current=wave_height&cell_selection=sea&timezone=auto'],
      ['Search (Open-Meteo Geo)', 'https://geocoding-api.open-meteo.com/v1/search?name=sydney&count=1&countryCode=AU'],
      ['Weather backup (MET Norway)', 'https://api.met.no/weatherapi/locationforecast/2.0/compact?lat=' + lat.toFixed(3) + '&lon=' + lon.toFixed(3)],
      ['Reverse geocode (Nominatim)', 'https://nominatim.openstreetmap.org/reverse?format=json&zoom=12&lat=' + lat + '&lon=' + lon]
    ];
    return Promise.all(checks.map(c => one(c[0], c[1])));
  }
  return { ping };
})();

/* ---------------- MoonService ---------------- */
const MoonService = (() => {
  const SYN = 29.530588853, KNOWN_NEW = Date.UTC(2000, 0, 6, 18, 14, 0) / 86400000;
  function info(date) {
    const now = date.getTime() / 86400000;
    let age = ((now - KNOWN_NEW) % SYN + SYN) % SYN;
    const illum = (1 - Math.cos(2 * Math.PI * age / SYN)) / 2, f = age / SYN;
    let phase, emoji;
    if (age < 1 || age >= SYN - 1) { phase = 'New Moon'; emoji = '🌑'; }
    else if (f < 0.22) { phase = 'Waxing Crescent'; emoji = '🌒'; }
    else if (f < 0.28) { phase = 'First Quarter'; emoji = '🌓'; }
    else if (f < 0.47) { phase = 'Waxing Gibbous'; emoji = '🌔'; }
    else if (f < 0.53) { phase = 'Full Moon'; emoji = '🌕'; }
    else if (f < 0.72) { phase = 'Waning Gibbous'; emoji = '🌖'; }
    else if (f < 0.78) { phase = 'Last Quarter'; emoji = '🌗'; }
    else { phase = 'Waning Crescent'; emoji = '🌘'; }
    return { age, illum, phase, emoji, illumPct: Math.round(illum * 100) };
  }
  // NOAA low-precision sun times
  function sun(date, lat, lon) {
    const rad = Math.PI / 180, deg = 180 / Math.PI;
    const d = Math.floor((Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()) / 86400000 - 10957.5)) + 2451545;
    const n = d - 2451545 + 0.0008, Jstar = n - lon / 360;
    const M = ((357.5291 + 0.98560028 * Jstar) % 360 + 360) % 360;
    const C = 1.9148 * Math.sin(M * rad) + 0.02 * Math.sin(2 * M * rad) + 0.0003 * Math.sin(3 * M * rad);
    const L = ((M + C + 180 + 102.9372) % 360 + 360) % 360;
    const Jtr = 2451545 + Jstar + 0.0053 * Math.sin(M * rad) - 0.0069 * Math.sin(2 * L * rad);
    const decl = Math.asin(Math.sin(L * rad) * Math.sin(23.44 * rad));
    const cosH = (Math.sin(-0.83 * rad) - Math.sin(lat * rad) * Math.sin(decl)) / (Math.cos(lat * rad) * Math.cos(decl));
    if (cosH > 1 || cosH < -1) { const noon = new Date(date); noon.setHours(12, 0, 0, 0); return { sunrise: new Date(noon - 6 * 3600000), sunset: new Date(noon.getTime() + 6 * 3600000) }; }
    const H = Math.acos(cosH) * deg, toDate = J => new Date((J - 2440587.5) * 86400000);
    return { sunrise: toDate(Jtr - H / 360), sunset: toDate(Jtr + H / 360) };
  }
  return { info, sun };
})();

/* ---------------- SolunarService ---------------- */
const SolunarService = (() => {
  function dayNumber(date) {
    const Y = date.getUTCFullYear(), M = date.getUTCMonth() + 1, D = date.getUTCDate();
    const UT = date.getUTCHours() + date.getUTCMinutes() / 60 + date.getUTCSeconds() / 3600;
    return 367 * Y - Math.floor(7 * (Y + Math.floor((M + 9) / 12)) / 4) + Math.floor(275 * M / 9) + D - 730530 + UT / 24;
  }
  function moonAltitude(date, lat, lon) {
    const rad = Math.PI / 180, deg = 180 / Math.PI, d = dayNumber(date);
    const N = (125.1228 - 0.0529538083 * d) * rad, i = 5.1454 * rad, w = (318.0634 + 0.1643573223 * d) * rad, a = 60.2666, e = 0.0549;
    let M = (115.3654 + 13.0649929509 * d) * rad; M %= 2 * Math.PI; if (M < 0) M += 2 * Math.PI;
    let E = M + e * Math.sin(M) * (1 + e * Math.cos(M)); for (let k = 0; k < 6; k++) E = E - (E - e * Math.sin(E) - M) / (1 - e * Math.cos(E));
    const xv = a * (Math.cos(E) - e), yv = a * (Math.sqrt(1 - e * e) * Math.sin(E)), v = Math.atan2(yv, xv), r = Math.sqrt(xv * xv + yv * yv);
    const xh = r * (Math.cos(N) * Math.cos(v + w) - Math.sin(N) * Math.sin(v + w) * Math.cos(i));
    const yh = r * (Math.sin(N) * Math.cos(v + w) + Math.cos(N) * Math.sin(v + w) * Math.cos(i));
    const zh = r * (Math.sin(v + w) * Math.sin(i));
    const lonE = Math.atan2(yh, xh), latE = Math.atan2(zh, Math.sqrt(xh * xh + yh * yh)), ecl = (23.4393 - 3.563e-7 * d) * rad;
    const xe = Math.cos(lonE) * Math.cos(latE);
    const ye = Math.sin(lonE) * Math.cos(latE) * Math.cos(ecl) - Math.sin(latE) * Math.sin(ecl);
    const ze = Math.sin(lonE) * Math.cos(latE) * Math.sin(ecl) + Math.sin(latE) * Math.cos(ecl);
    const RA = Math.atan2(ye, xe), Dec = Math.atan2(ze, Math.sqrt(xe * xe + ye * ye));
    const ws = 282.9404 + 4.70935e-5 * d, Ms = 356.047 + 0.9856002585 * d, Ls = ws + Ms;
    const UT = date.getUTCHours() + date.getUTCMinutes() / 60 + date.getUTCSeconds() / 3600;
    const GMST0 = ((Ls + 180) % 360 + 360) % 360;
    let LST = ((GMST0 + UT * 15.04107 + lon) % 360 + 360) % 360;
    let HA = ((LST - RA * deg) % 360 + 360) % 360; if (HA > 180) HA -= 360; HA *= rad;
    const latR = lat * rad;
    return Math.asin(Math.sin(latR) * Math.sin(Dec) + Math.cos(latR) * Math.cos(Dec) * Math.cos(HA)) * deg;
  }
  function periods(baseDate, lat, lon) {
    const start = new Date(baseDate); start.setHours(0, 0, 0, 0);
    const step = 10 * 60000, n = 24 * 6; let prev = null, prevAlt = null; const rises = [], sets = [], samples = [];
    for (let k = 0; k <= n; k++) { const t = new Date(start.getTime() + k * step), alt = moonAltitude(t, lat, lon); samples.push({ t, alt }); if (prevAlt !== null) { if (prevAlt < 0 && alt >= 0) rises.push(new Date((prev.getTime() + t.getTime()) / 2)); if (prevAlt >= 0 && alt < 0) sets.push(new Date((prev.getTime() + t.getTime()) / 2)); } prev = t; prevAlt = alt; }
    let maxS = samples[0], minS = samples[0]; for (const s of samples) { if (s.alt > maxS.alt) maxS = s; if (s.alt < minS.alt) minS = s; }
    const majors = [{ label: 'Major', t: maxS.t.getTime(), len: 120 }, { label: 'Major', t: minS.t.getTime(), len: 120 }];
    const minors = []; rises.forEach(t => minors.push({ label: 'Minor', t: t.getTime(), len: 60 })); sets.forEach(t => minors.push({ label: 'Minor', t: t.getTime(), len: 60 }));
    return { majors, minors };
  }
  function strength(nowMs, sol) {
    let best = 0; const consider = [...sol.majors.map(p => ({ ...p, w: 1 })), ...sol.minors.map(p => ({ ...p, w: 0.6 }))];
    for (const p of consider) { const dt = Math.abs(nowMs - p.t) / 60000, half = p.len / 2; if (dt <= half) { const c = 1 - (dt / half); best = Math.max(best, p.w * (0.5 + 0.5 * c)); } }
    return Util.clamp(0.18 + best, 0, 1);
  }
  return { periods, strength, dayNumber, moonAltitude };
})();

/* ---------------- TideService (on-device engine + live attempt) ---------------- */
const TideService = (() => {
  const AMP = { M2: 0.50, S2: 0.13, K1: 0.14, O1: 0.10 };
  function _moonRADec(d) {
    const rad = Math.PI / 180;
    const N = (125.1228 - 0.0529538083 * d) * rad, i = 5.1454 * rad, w = (318.0634 + 0.1643573223 * d) * rad, a = 60.2666, e = 0.0549;
    let M = (115.3654 + 13.0649929509 * d) * rad; M %= 2 * Math.PI; if (M < 0) M += 2 * Math.PI;
    let E = M + e * Math.sin(M) * (1 + e * Math.cos(M)); for (let k = 0; k < 6; k++) E = E - (E - e * Math.sin(E) - M) / (1 - e * Math.cos(E));
    const xv = a * (Math.cos(E) - e), yv = a * (Math.sqrt(1 - e * e) * Math.sin(E)), v = Math.atan2(yv, xv), r = Math.sqrt(xv * xv + yv * yv);
    const xh = r * (Math.cos(N) * Math.cos(v + w) - Math.sin(N) * Math.sin(v + w) * Math.cos(i));
    const yh = r * (Math.sin(N) * Math.cos(v + w) + Math.cos(N) * Math.sin(v + w) * Math.cos(i));
    const zh = r * (Math.sin(v + w) * Math.sin(i));
    const lonE = Math.atan2(yh, xh), latE = Math.atan2(zh, Math.sqrt(xh * xh + yh * yh)), ecl = (23.4393 - 3.563e-7 * d) * rad;
    const xe = Math.cos(lonE) * Math.cos(latE), ye = Math.sin(lonE) * Math.cos(latE) * Math.cos(ecl) - Math.sin(latE) * Math.sin(ecl), ze = Math.sin(lonE) * Math.cos(latE) * Math.sin(ecl) + Math.sin(latE) * Math.cos(ecl);
    return { RA: Math.atan2(ye, xe), Dec: Math.atan2(ze, Math.sqrt(xe * xe + ye * ye)) };
  }
  function _sunRADec(d) {
    const rad = Math.PI / 180, w = 282.9404 + 4.70935e-5 * d, e = 0.016709; let M = ((356.047 + 0.9856002585 * d) % 360 + 360) % 360 * rad;
    let E = M + e * Math.sin(M) * (1 + e * Math.cos(M));
    const xv = Math.cos(E) - e, yv = Math.sqrt(1 - e * e) * Math.sin(E), v = Math.atan2(yv, xv), r = Math.sqrt(xv * xv + yv * yv);
    const lon = v + w * rad, ecl = (23.4393 - 3.563e-7 * d) * rad, xs = r * Math.cos(lon), ys = r * Math.sin(lon);
    const xe = xs, ye = ys * Math.cos(ecl), ze = ys * Math.sin(ecl);
    return { RA: Math.atan2(ye, xe), Dec: Math.atan2(ze, Math.sqrt(xe * xe + ye * ye)) };
  }
  function _ha(date, lon, which) {
    const rad = Math.PI / 180, deg = 180 / Math.PI, d = SolunarService.dayNumber(date);
    const eq = which === 'moon' ? _moonRADec(d) : _sunRADec(d);
    const ws = 282.9404 + 4.70935e-5 * d, Ms = 356.047 + 0.9856002585 * d, Ls = ws + Ms, GMST0 = ((Ls + 180) % 360 + 360) % 360;
    const UT = date.getUTCHours() + date.getUTCMinutes() / 60 + date.getUTCSeconds() / 3600;
    let LST = ((GMST0 + UT * 15.04107 + lon) % 360 + 360) % 360, HA = ((LST - eq.RA * deg) % 360 + 360) % 360; if (HA > 180) HA -= 360;
    return { HA: HA * rad, dec: eq.Dec };
  }
  function height(date, lat, lon, amp) {
    amp = amp || AMP;
    const m = _ha(date, lon, 'moon'), s = _ha(date, lon, 'sun');
    const semi = amp.M2 * Math.cos(2 * m.HA) + amp.S2 * Math.cos(2 * s.HA);
    const norm = Math.sin(2 * 23.44 * Math.PI / 180);
    const diur = (amp.K1 + amp.O1) * (Math.sin(2 * m.dec) / norm) * Math.cos(m.HA);
    return semi + diur;
  }
  function refine(pts) {
    const ev = [];
    for (let i = 1; i < pts.length - 1; i++) {
      const a = pts[i - 1].h, b = pts[i].h, c = pts[i + 1].h;
      const isH = b >= a && b >= c && (b > a || b > c), isL = b <= a && b <= c && (b < a || b < c); if (!isH && !isL) continue;
      const den = (a - 2 * b + c); let off = den !== 0 ? 0.5 * (a - c) / den : 0; off = Util.clamp(off, -0.5, 0.5);
      const dt = pts[i + 1].t - pts[i].t;
      ev.push({ type: isH ? 'High' : 'Low', t: pts[i].t + off * dt, h: b - 0.25 * (a - c) * off });
    }
    return ev;
  }
  function engineExtrema(now, lat, lon) {
    const start = now.getTime() - 13 * 3600000, end = now.getTime() + 7.7 * 86400000, step = 15 * 60000, pts = [];
    for (let t = start; t <= end; t += step) pts.push({ t, h: height(new Date(t), lat, lon) });
    return refine(pts);
  }
  function fromHourly(times, hs) {
    const pts = []; for (let i = 0; i < times.length; i++) if (hs[i] != null) pts.push({ t: new Date(times[i]).getTime(), h: hs[i] });
    if (pts.length < 6) return null; const ev = refine(pts); return ev.length >= 2 ? ev : null;
  }
  function valid(ev) { return Array.isArray(ev) && ev.length >= 2 && ev.every(e => e && (e.type === 'High' || e.type === 'Low') && isFinite(e.t) && isFinite(e.h) && Math.abs(e.h) < 15); }
  function interp(ext, t) {
    if (!ext.length) return null;
    if (t <= ext[0].t) return { h: ext[0].h, dir: ext[0].type === 'High' ? 'falling' : 'rising' };
    if (t >= ext[ext.length - 1].t) { const e = ext[ext.length - 1]; return { h: e.h, dir: e.type === 'High' ? 'falling' : 'rising' }; }
    let i = 0; while (i < ext.length - 1 && !(ext[i].t <= t && t < ext[i + 1].t)) i++;
    const a = ext[i], b = ext[i + 1], f = (t - a.t) / (b.t - a.t);
    return { h: (a.h + b.h) / 2 + (a.h - b.h) / 2 * Math.cos(Math.PI * f), dir: b.h > a.h ? 'rising' : 'falling' };
  }
  // ===== DATA-DRIVEN HARMONIC ENGINE (copyright-free; fits real constituents from live data) =====
  // Standard astronomical angular speeds (deg/hour) — Doodson/IHO convention (NOAA CO-OPS;
  // Pugh & Woodworth 2014; Foreman 1977). Form factor F = (K1+O1)/(M2+S2) (Courtier 1938).
  const SPEEDS = { M2: 28.9841042, S2: 30.0, N2: 28.4397295, K1: 15.0410686, O1: 13.9430356 };
  function solve(A, b) { // Gauss–Jordan with partial pivoting; returns solution vector or null
    const n = b.length, M = A.map((r, i) => r.slice().concat([b[i]]));
    for (let c = 0; c < n; c++) {
      let p = c; for (let r = c + 1; r < n; r++) if (Math.abs(M[r][c]) > Math.abs(M[p][c])) p = r;
      if (Math.abs(M[p][c]) < 1e-12) return null;
      const tmp = M[c]; M[c] = M[p]; M[p] = tmp;
      const piv = M[c][c]; for (let k = c; k <= n; k++) M[c][k] /= piv;
      for (let r = 0; r < n; r++) { if (r === c) continue; const f = M[r][c]; for (let k = c; k <= n; k++) M[r][k] -= f * M[c][k]; }
    }
    return M.map(r => r[n]);
  }
  // Least-squares harmonic analysis: η(t)=Z0+Σ[a_k cos(ω_k τ)+b_k sin(ω_k τ)] (linear in unknowns).
  function fit(times, heights) {
    const pts = [];
    for (let i = 0; i < times.length; i++) { const h = heights[i]; if (h != null && isFinite(h)) pts.push({ t: new Date(times[i]).getTime(), h: +h }); }
    if (pts.length < 24) return null;
    const names = Object.keys(SPEEDS), omega = names.map(n => SPEEDS[n] * Math.PI / 180), ncol = 1 + 2 * names.length;
    const epoch = pts[0].t;
    const ATA = Array.from({ length: ncol }, () => new Array(ncol).fill(0)), ATy = new Array(ncol).fill(0);
    for (const p of pts) {
      const tau = (p.t - epoch) / 3600000, row = new Array(ncol); row[0] = 1;
      for (let k = 0; k < names.length; k++) { row[1 + 2 * k] = Math.cos(omega[k] * tau); row[2 + 2 * k] = Math.sin(omega[k] * tau); }
      for (let i = 0; i < ncol; i++) { ATy[i] += row[i] * p.h; for (let j = 0; j < ncol; j++) ATA[i][j] += row[i] * row[j]; }
    }
    const x = solve(ATA, ATy); if (!x) return null;
    const z0 = x[0], comps = names.map((n, k) => { const a = x[1 + 2 * k], b = x[2 + 2 * k]; return { name: n, speed: SPEEDS[n], a, b, amp: Math.hypot(a, b) }; });
    let ss = 0; for (const p of pts) { const tau = (p.t - epoch) / 3600000; let h = z0; for (let k = 0; k < comps.length; k++) h += comps[k].a * Math.cos(omega[k] * tau) + comps[k].b * Math.sin(omega[k] * tau); ss += (h - p.h) ** 2; }
    const rms = Math.sqrt(ss / pts.length);
    const amp = n => (comps.find(c => c.name === n) || { amp: 0 }).amp;
    const m2 = amp('M2'), F = (amp('K1') + amp('O1')) / Math.max(1e-6, amp('M2') + amp('S2'));
    return { epoch, z0, comps, rms, n: pts.length, m2, F };
  }
  function fitValid(f) { return !!(f && f.n >= 24 && isFinite(f.m2) && f.m2 >= 0.03 && f.m2 < 6 && isFinite(f.rms) && f.rms < Math.max(0.15, 0.6 * f.m2)); }
  function predictFit(f, t) { const tau = (t - f.epoch) / 3600000; let h = f.z0; for (const c of f.comps) { const w = c.speed * Math.PI / 180; h += c.a * Math.cos(w * tau) + c.b * Math.sin(w * tau); } return h; }
  function fittedExtrema(f, now) {
    const start = now.getTime() - 13 * 3600000, end = now.getTime() + 7.7 * 86400000, step = 12 * 60000, pts = [];
    for (let t = start; t <= end; t += step) pts.push({ t, h: predictFit(f, t) });
    return refine(pts);
  }
  // ===== Cold-start regional calibration (form factor + mean range by AU region) =====
  // Regime facts grounded (Pugh & Woodworth 2014; AHO ANTT; well-known port characteristics).
  // Amplitudes are REGIONAL ESTIMATES (labelled) — exact per-port constants need the CC BY 4.0
  // TICON-4 dataset (see TIDE-ENGINE.md); never presented as official.
  const REGIONS = [
    { name: 'NSW / SE coast', test: (la, lo) => la <= -28 && la >= -38 && lo >= 149, F: 0.18, spring: 1.3, neap: 0.8 },
    { name: 'SE QLD', test: (la, lo) => la < -24 && la > -29 && lo >= 152, F: 0.30, spring: 1.8, neap: 1.1 },
    { name: 'Tropical QLD', test: (la, lo) => la <= -10 && la > -24 && lo >= 145, F: 0.5, spring: 2.6, neap: 1.4 },
    { name: 'Gulf of Carpentaria', test: (la, lo) => la > -18 && lo >= 135 && lo < 145, F: 2.2, spring: 1.8, neap: 1.0 },
    { name: 'NT / Top End', test: (la, lo) => la > -16 && lo >= 129 && lo < 138, F: 0.6, spring: 4.5, neap: 2.2 },
    { name: 'Kimberley / NW (macro-tidal)', test: (la, lo) => la > -20 && lo >= 121 && lo < 129, F: 0.4, spring: 8.0, neap: 4.0 },
    { name: 'Pilbara NW', test: (la, lo) => la <= -18 && la > -24 && lo < 121, F: 0.8, spring: 3.0, neap: 1.6 },
    { name: 'SW WA (diurnal, micro-tidal)', test: (la, lo) => la <= -28 && lo < 119, F: 1.6, spring: 0.7, neap: 0.5 },
    { name: 'SA gulfs / Vic / Tas', test: (la, lo) => la <= -33 && lo >= 129 && lo < 149, F: 0.25, spring: 1.6, neap: 0.9 }
  ];
  function regionFor(lat, lon) { return REGIONS.find(r => { try { return r.test(lat, lon); } catch (_) { return false; } }) || { name: 'Default SE-coast model', F: 0.18, spring: 1.3, neap: 0.8 }; }
  function ampForRegion(lat, lon) { const r = regionFor(lat, lon), M2 = (r.spring + r.neap) / 4, S2 = Math.max(0, (r.spring - r.neap) / 4), KO = r.F * (M2 + S2); return { amp: { M2, S2, K1: KO * 0.58, O1: KO * 0.42 }, region: r }; }
  function regionalExtrema(now, lat, lon) {
    const { amp } = ampForRegion(lat, lon);
    const start = now.getTime() - 13 * 3600000, end = now.getTime() + 7.7 * 86400000, step = 15 * 60000, pts = [];
    for (let t = start; t <= end; t += step) pts.push({ t, h: height(new Date(t), lat, lon, amp) });
    return refine(pts);
  }
  // Best OFFLINE source: cached fit (real data) → regional engine → generic engine.
  function coldExtrema(lat, lon, now) {
    const ch = CacheService.getHarm(lat, lon);
    if (ch && fitValid(ch.fit)) { const ev = fittedExtrema(ch.fit, now); if (valid(ev)) return { extrema: ev, source: 'Fitted to live data (n=' + ch.fit.n + ')', method: 'fitted' }; }
    const rev = regionalExtrema(now, lat, lon); if (valid(rev)) return { extrema: rev, source: 'Tide engine · ' + regionFor(lat, lon).name, method: 'regional' };
    return { extrema: engineExtrema(now, lat, lon), source: 'Tide engine (generic)', method: 'generic' };
  }
  function hav(la1, lo1, la2, lo2) { const R = 6371, p = Math.PI / 180, dla = (la2 - la1) * p, dlo = (lo2 - lo1) * p; const a = Math.sin(dla / 2) ** 2 + Math.cos(la1 * p) * Math.cos(la2 * p) * Math.sin(dlo / 2) ** 2; return 2 * R * Math.asin(Math.sqrt(a)); }
  // BoM via the free, no-key austides community proxy (AU standard ports). UNOFFICIAL, best-effort.
  async function fetchAusTides(lat, lon, signal) {
    try {
      const sr = await fetch('https://austides.vercel.app/v1/stations', { signal, cache: 'no-store' }); if (!sr.ok) return { ext: null, reason: 'austides stations HTTP ' + sr.status };
      const sj = await sr.json(); let arr = Array.isArray(sj) ? sj : (sj && (sj.data || sj.stations || sj.results)); if (!Array.isArray(arr)) return { ext: null, reason: 'austides station list unavailable' };
      const sts = arr.map(s => ({ id: s.id || s.station_id || s.slug, lat: +(s.lat != null ? s.lat : s.latitude), lon: +(s.lon != null ? s.lon : (s.lng != null ? s.lng : s.longitude)), name: s.name })).filter(s => s.id && isFinite(s.lat) && isFinite(s.lon));
      let best = null, bd = Infinity; for (const s of sts) { const d = hav(lat, lon, s.lat, s.lon); if (d < bd) { bd = d; best = s; } }
      if (!best || bd > 180) return { ext: null, reason: 'No austides/BoM port within 180 km' };
      const ds = [0, 1, 2].map(o => { const dt = new Date(Date.now() + o * 86400000); return dt.getFullYear() + '-' + String(dt.getMonth() + 1).padStart(2, '0') + '-' + String(dt.getDate()).padStart(2, '0'); });
      const res = await Promise.all(ds.map(dt => fetch('https://austides.vercel.app/v1/stations/' + encodeURIComponent(best.id) + '/tides?date=' + dt, { signal, cache: 'no-store' }).then(r => r.ok ? r.json() : null).catch(() => null)));
      const ev = [], seen = new Set();
      res.forEach(j => { const data = j && (j.data || j.tides || j.predictions); if (Array.isArray(data)) data.forEach(e => { const t = Date.parse(e.time || e.dt || e.datetime); const h = +(e.height_m != null ? e.height_m : e.height); const ty = /h/i.test(e.type || '') ? 'High' : (/l/i.test(e.type || '') ? 'Low' : null); if (isFinite(t) && isFinite(h) && ty) { const k = Math.round(t / 600000); if (!seen.has(k)) { seen.add(k); ev.push({ type: ty, t, h }); } } }); });
      ev.sort((a, b) => a.t - b.t);
      return valid(ev) ? { ext: ev, source: 'BoM · ' + (best.name || 'austides') + ' (unofficial proxy)' } : { ext: null, reason: 'austides returned no usable extrema' };
    } catch (e) { return { ext: null, reason: 'austides error: ' + (e && e.name === 'AbortError' ? 'timeout' : (e && e.message || e)) }; }
  }

  // Normalised Tide object
  function build(extrema, now, real, source, fallbackReason, method) {
    const ext = extrema.slice().sort((x, y) => x.t - y.t), nowMs = now.getTime();
    const cur = interp(ext, nowMs), curHeight = cur ? cur.h : null, dir = cur ? cur.dir : 'steady';
    const future = ext.filter(e => e.t > nowMs);
    const nextHigh = future.find(e => e.type === 'High') || null, nextLow = future.find(e => e.type === 'Low') || null, next = future[0] || null;
    let nearest = null, nd = Infinity; for (const e of ext) { const dd = Math.abs(e.t - nowMs); if (dd < nd) { nd = dd; nearest = e; } }
    let state; if (nearest && nd <= 40 * 60000) state = nearest.type; else state = dir === 'rising' ? 'Run-in' : (dir === 'falling' ? 'Run-out' : 'Slack');
    const events48 = ext.filter(e => e.t >= nowMs - 40 * 60000 && e.t <= nowMs + 48 * 3600000);
    const events7d = ext.filter(e => e.t >= nowMs - 40 * 60000 && e.t <= nowMs + 7 * 86400000);
    method = method || (real ? 'live' : 'generic');
    const confidence = real ? 'High' : (method === 'fitted' ? 'Good' : 'Modelled');
    return {
      ok: true, real, source, provider: source, method, confidence,
      fallbackReason: fallbackReason || (real ? null : (method === 'fitted' ? 'Fitted to recent live data (offline)' : 'No live tide source — using the on-device harmonic engine')),
      state, dir, curHeight, nextHigh, nextLow, next, nextType: next ? next.type : '—',
      events48, events7d, extrema: ext
    };
  }
  function series(ext, now, hours) { const out = [], start = now.getTime(); for (let h = 0; h <= hours; h++) { const t = start + h * 3600000, v = interp(ext, t); out.push({ t, h: v ? v.h : 0 }); } return out; }
  // Live attempt: Open-Meteo Marine sea_level (free, no key, CORS). Coarse inshore → engine backup.
  async function fetchLive(lat, lon, signal) {
    // ~7-day hourly window (2 past + 5 forecast) → enough samples to fit M2/S2/N2/K1/O1 well.
    const url = 'https://marine-api.open-meteo.com/v1/marine?latitude=' + lat + '&longitude=' + lon + '&hourly=sea_level_height_msl&cell_selection=sea&timezone=auto&past_days=2&forecast_days=5';
    const t0 = Date.now();
    try {
      const r = await fetch(url, { signal, cache: 'no-store' });
      DebugService.record('tide', { url, attempted: true, status: r.status, ms: Date.now() - t0 });
      if (!r.ok) return { ext: null, reason: 'Open-Meteo Marine HTTP ' + r.status };
      const j = await r.json();
      const hs = j && j.hourly && j.hourly.sea_level_height_msl;
      if (!hs || hs.filter(v => v != null).length < 12) return { ext: null, reason: 'No usable marine cell at this coordinate (ocean-only 8 km grid)' };
      const raw = { times: j.hourly.time, heights: hs };
      const ev = fromHourly(j.hourly.time, hs);
      return valid(ev) ? { ext: ev, source: 'Open-Meteo Marine', raw } : { ext: null, reason: 'Marine data did not resolve 2+ tide turning points', raw };
    } catch (e) {
      DebugService.record('tide', { url, attempted: true, status: 'error', ms: Date.now() - t0, error: String(e && e.message || e) });
      return { ext: null, reason: 'Marine request failed: ' + (e && e.name === 'AbortError' ? 'timeout/aborted' : (e && e.message || e)) };
    }
  }
  return { engineExtrema, fetchLive, build, series, interp, valid, fit, fitValid, predictFit, fittedExtrema, regionalExtrema, coldExtrema, regionFor, ampForRegion, fetchAusTides, SPEEDS };
})();

/* ---------------- WeatherService ---------------- */
const WeatherService = (() => {
  const WMO = { 0: ['Clear', '☀️'], 1: ['Mainly clear', '🌤️'], 2: ['Partly cloudy', '⛅'], 3: ['Overcast', '☁️'], 45: ['Fog', '🌫️'], 48: ['Rime fog', '🌫️'], 51: ['Light drizzle', '🌦️'], 53: ['Drizzle', '🌦️'], 55: ['Heavy drizzle', '🌧️'], 61: ['Light rain', '🌦️'], 63: ['Rain', '🌧️'], 65: ['Heavy rain', '🌧️'], 71: ['Light snow', '🌨️'], 73: ['Snow', '🌨️'], 75: ['Heavy snow', '❄️'], 80: ['Showers', '🌦️'], 81: ['Showers', '🌧️'], 82: ['Violent showers', '⛈️'], 95: ['Thunderstorm', '⛈️'], 96: ['Storm + hail', '⛈️'], 99: ['Storm + hail', '⛈️'] };
  const wmo = c => WMO[c] || ['—', '🌥️'];
  function omUrl(lat, lon) {
    return 'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon +
      '&current=temperature_2m,apparent_temperature,relative_humidity_2m,is_day,precipitation,weather_code,surface_pressure,cloud_cover,wind_speed_10m,wind_direction_10m,wind_gusts_10m' +
      '&hourly=temperature_2m,weather_code,wind_speed_10m,wind_direction_10m,wind_gusts_10m,surface_pressure,precipitation_probability' +
      '&daily=weather_code,temperature_2m_max,temperature_2m_min,sunrise,sunset,wind_speed_10m_max,wind_gusts_10m_max,wind_direction_10m_dominant,precipitation_sum,precipitation_probability_max,uv_index_max' +
      '&forecast_days=7&timezone=auto&windspeed_unit=kmh';
  }
  function metUrl(lat, lon) { return 'https://api.met.no/weatherapi/locationforecast/2.0/compact?lat=' + lat.toFixed(4) + '&lon=' + lon.toFixed(4); }
  function metSymWmo(s) { if (!s) return 3; s = s.replace(/_(day|night|polartwilight)$/, ''); const M = { clearsky: 0, fair: 1, partlycloudy: 2, cloudy: 3, fog: 45, lightrainshowers: 80, rainshowers: 80, heavyrainshowers: 82, lightrain: 51, rain: 63, heavyrain: 65, lightsnow: 71, snow: 73, heavysnow: 75, rainandthunder: 95, thunderstorm: 95 }; return M[s] != null ? M[s] : 3; }
  function adaptMet(j, lat, lon) {
    const ts = j && j.properties && j.properties.timeseries; if (!ts || !ts.length) return null;
    const hourly = { time: [], temperature_2m: [], weather_code: [], wind_speed_10m: [], wind_direction_10m: [], wind_gusts_10m: [], surface_pressure: [], precipitation_probability: [] };
    ts.forEach(e => { const ins = e.data.instant.details || {}, n1 = e.data.next_1_hours || {}, sum = n1.summary || {}, det = n1.details || {};
      hourly.time.push(e.time); hourly.temperature_2m.push(ins.air_temperature); hourly.weather_code.push(metSymWmo(sum.symbol_code));
      const ws = ins.wind_speed != null ? ins.wind_speed * 3.6 : null; hourly.wind_speed_10m.push(ws);
      hourly.wind_direction_10m.push(ins.wind_from_direction); hourly.wind_gusts_10m.push(ins.wind_speed_of_gust != null ? ins.wind_speed_of_gust * 3.6 : ws);
      hourly.surface_pressure.push(ins.air_pressure_at_sea_level); hourly.precipitation_probability.push(det.probability_of_precipitation != null ? det.probability_of_precipitation : 0); });
    const i0 = ts[0].data.instant.details || {}, c1 = (ts[0].data.next_1_hours || {}).summary || {}, s0 = MoonService.sun(new Date(), lat, lon), nowMs = Date.now();
    const cur = { temperature_2m: i0.air_temperature, apparent_temperature: i0.air_temperature, relative_humidity_2m: i0.relative_humidity, is_day: (nowMs >= s0.sunrise.getTime() && nowMs <= s0.sunset.getTime()) ? 1 : 0, precipitation: 0, cloud_cover: i0.cloud_area_fraction, weather_code: metSymWmo(c1.symbol_code), surface_pressure: i0.air_pressure_at_sea_level, wind_speed_10m: i0.wind_speed != null ? i0.wind_speed * 3.6 : 0, wind_direction_10m: i0.wind_from_direction || 0, wind_gusts_10m: i0.wind_speed_of_gust != null ? i0.wind_speed_of_gust * 3.6 : (i0.wind_speed != null ? i0.wind_speed * 3.6 : 0) };
    const days = {}, order = [];
    hourly.time.forEach((t, k) => { const dt = new Date(t), key = dt.getFullYear() + '-' + String(dt.getMonth() + 1).padStart(2, '0') + '-' + String(dt.getDate()).padStart(2, '0'); if (!days[key]) { days[key] = { tmax: -99, tmin: 99, wmax: 0, gmax: 0, dirs: [], pmax: 0, codes: [], noon: 3 }; order.push(key); } const D = days[key], tp = hourly.temperature_2m[k]; if (tp != null) { D.tmax = Math.max(D.tmax, tp); D.tmin = Math.min(D.tmin, tp); } const w = hourly.wind_speed_10m[k]; if (w != null) D.wmax = Math.max(D.wmax, w); const g = hourly.wind_gusts_10m[k]; if (g != null) D.gmax = Math.max(D.gmax, g); if (hourly.wind_direction_10m[k] != null) D.dirs.push(hourly.wind_direction_10m[k]); D.pmax = Math.max(D.pmax, hourly.precipitation_probability[k] || 0); D.codes.push(hourly.weather_code[k]); if (dt.getHours() === 12) D.noon = hourly.weather_code[k]; });
    const daily = { time: [], weather_code: [], temperature_2m_max: [], temperature_2m_min: [], sunrise: [], sunset: [], wind_speed_10m_max: [], wind_gusts_10m_max: [], wind_direction_10m_dominant: [], precipitation_sum: [], precipitation_probability_max: [], uv_index_max: [] };
    order.slice(0, 7).forEach(key => { const D = days[key], dd = new Date(key + 'T12:00:00'), st = MoonService.sun(dd, lat, lon), worst = Math.max.apply(null, D.codes), dir = D.dirs.length ? D.dirs.reduce((a, b) => a + b, 0) / D.dirs.length : 0; daily.time.push(key); daily.weather_code.push(D.noon || worst); daily.temperature_2m_max.push(D.tmax); daily.temperature_2m_min.push(D.tmin); daily.sunrise.push(st.sunrise.toISOString()); daily.sunset.push(st.sunset.toISOString()); daily.wind_speed_10m_max.push(D.wmax); daily.wind_gusts_10m_max.push(D.gmax); daily.wind_direction_10m_dominant.push(dir); daily.precipitation_sum.push(0); daily.precipitation_probability_max.push(D.pmax); daily.uv_index_max.push(null); });
    return { current: cur, hourly, daily };
  }
  async function fetchOM(lat, lon, signal) { const t0 = Date.now(), url = omUrl(lat, lon); try { const r = await fetch(url, { signal, cache: 'no-store' }); DebugService.record('weather', { url, attempted: true, status: r.status, ms: Date.now() - t0, provider: 'Open-Meteo' }); if (!r.ok) return null; const j = await r.json(); return (j && j.current) ? { f: j, src: 'Open-Meteo' } : null; } catch (e) { DebugService.record('weather', { url, attempted: true, status: 'error', ms: Date.now() - t0, error: String(e && e.message || e) }); return null; } }
  async function fetchMet(lat, lon, signal) { const t0 = Date.now(), url = metUrl(lat, lon); try { const r = await fetch(url, { signal, cache: 'no-store', headers: { 'User-Agent': 'SendIt-Fishing/2.0 fishing-app' } }); if (!r.ok) return null; const j = await r.json(); const a = adaptMet(j, lat, lon); DebugService.record('weather', { url, attempted: true, status: r.status, ms: Date.now() - t0, provider: 'MET Norway (backup)' }); return (a && a.current) ? { f: a, src: 'MET Norway (backup)' } : null; } catch (_) { return null; } }
  async function get(lat, lon, signal) { return (await fetchOM(lat, lon, signal)) || (await fetchMet(lat, lon, signal)) || null; }
  async function swell(lat, lon, signal) { const url = 'https://marine-api.open-meteo.com/v1/marine?latitude=' + lat + '&longitude=' + lon + '&current=wave_height,wave_period,sea_surface_temperature&cell_selection=sea&timezone=auto'; try { const r = await fetch(url, { signal, cache: 'no-store' }); if (!r.ok) return null; const j = await r.json(); return j && j.current ? j.current : null; } catch (_) { return null; } }
  // neutral synth so the score can run with no weather
  function synth(lat, lon) {
    const daily = { time: [], weather_code: [], temperature_2m_max: [], temperature_2m_min: [], sunrise: [], sunset: [], wind_speed_10m_max: [], wind_gusts_10m_max: [], wind_direction_10m_dominant: [], precipitation_sum: [], precipitation_probability_max: [], uv_index_max: [] };
    const b = new Date(); b.setHours(0, 0, 0, 0);
    for (let i = 0; i < 7; i++) { const dt = new Date(b.getTime() + i * 86400000), st = MoonService.sun(dt, lat, lon); daily.time.push(dt.getFullYear() + '-' + String(dt.getMonth() + 1).padStart(2, '0') + '-' + String(dt.getDate()).padStart(2, '0')); daily.weather_code.push(2); daily.temperature_2m_max.push(20); daily.temperature_2m_min.push(12); daily.sunrise.push(st.sunrise.toISOString()); daily.sunset.push(st.sunset.toISOString()); daily.wind_speed_10m_max.push(0); daily.wind_gusts_10m_max.push(0); daily.wind_direction_10m_dominant.push(0); daily.precipitation_sum.push(0); daily.precipitation_probability_max.push(0); daily.uv_index_max.push(null); }
    const hourly = { time: [], surface_pressure: [], wind_speed_10m: [], wind_direction_10m: [], wind_gusts_10m: [], temperature_2m: [], weather_code: [], precipitation_probability: [] };
    const h0 = new Date(); h0.setMinutes(0, 0, 0);
    for (let i = 0; i < 48; i++) { const t = new Date(h0.getTime() + i * 3600000); hourly.time.push(t.toISOString()); hourly.surface_pressure.push(1015); hourly.wind_speed_10m.push(0); hourly.wind_direction_10m.push(0); hourly.wind_gusts_10m.push(0); hourly.temperature_2m.push(18); hourly.weather_code.push(2); hourly.precipitation_probability.push(0); }
    return { current: {}, daily, hourly };
  }
  return { get, swell, wmo, synth };
})();

/* ---------------- GeocodingService ---------------- */
const GeocodingService = (() => {
  async function search(q, signal) {
    const url = 'https://geocoding-api.open-meteo.com/v1/search?name=' + encodeURIComponent(q) + '&count=6&language=en&countryCode=AU';
    try { const r = await fetch(url, { signal }); if (!r.ok) return []; const j = await r.json(); return (j.results || []).map(x => ({ name: x.name + (x.admin1 ? ', ' + x.admin1 : ''), lat: x.latitude, lon: x.longitude, region: x.admin1 || '', country: x.country || 'Australia' })); } catch (_) { return []; }
  }
  async function reverse(lat, lon, signal) {
    try { const r = await fetch('https://nominatim.openstreetmap.org/reverse?format=json&zoom=12&lat=' + lat + '&lon=' + lon, { signal }); if (!r.ok) return 'My Location'; const j = await r.json(); const a = j.address || {}; return (a.suburb || a.town || a.city || a.village || a.hamlet || a.county || 'My Location') + (a.state ? ', ' + a.state : ''); } catch (_) { return 'My Location'; }
  }
  return { search, reverse };
})();

/* ---------------- SpeciesEngine (11 AU species) ---------------- */
const SpeciesEngine = (() => {
  const DB = [
    { key: 'bream', name: 'Bream', emoji: '🐟', season: [3, 4, 5, 6, 7, 8], time: ['dawn', 'dusk', 'night'], wind: 25, tide: 'run-out', baits: ['Live nippers', 'Peeled prawn', 'Mullet strip', 'Chicken breast', 'Bread'], rig: 'Light running sinker, 6lb fluoro, #1–1/0 suicide', tip: 'Berley lightly; fish structure on the run-out — racks, pylons, snags.' },
    { key: 'flathead', name: 'Flathead', emoji: '🐠', season: [9, 10, 11, 12, 1, 2, 3], time: ['day', 'dawn', 'dusk'], wind: 30, tide: 'run-out', baits: ['Soft plastic jerk shad', 'Live poddy mullet', 'Pilchard', 'Whitebait'], rig: '1/4–3/8oz jighead on a 4" plastic; 10–15lb leader', tip: 'Slow-hop the bottom over sand flats & drop-offs on the run-out.' },
    { key: 'whiting', name: 'Whiting', emoji: '🐟', season: [10, 11, 12, 1, 2, 3], time: ['day', 'dawn'], wind: 22, tide: 'run-in', baits: ['Live beach worms', 'Blood worms', 'Pipis', 'Live nippers', 'Surface popper'], rig: 'Long-shank #4, light running ball sinker, 4–6lb leader', tip: 'Run-in over clean sand; keep moving — whiting feed in patches.' },
    { key: 'snapper', name: 'Snapper', emoji: '🐠', season: [7, 8, 9, 10, 11], time: ['dawn', 'dusk', 'night'], wind: 25, tide: 'run-in', baits: ['Whole squid', 'Pilchard', '5–7" soft plastic', 'Slimy mackerel', 'Octopus'], rig: 'Paternoster or running sinker, 30–40lb leader, 5/0–7/0', tip: 'Low-light bite over reef & gravel; berley a trail, float baits in current.' },
    { key: 'mulloway', name: 'Mulloway', emoji: '🐋', season: [3, 4, 5, 6, 7, 8], time: ['night', 'dusk', 'dawn'], wind: 28, tide: 'tide-change', baits: ['Live tailor', 'Live mullet', 'Whole squid', 'Squid head', 'Large soft plastic'], rig: 'Running sinker, 50–60lb leader, 8/0 circle (snell for live bait)', tip: 'Deep holes, bridge lights & beach gutters on the tide change, around new/full moon.' },
    { key: 'tailor', name: 'Tailor', emoji: '🐟', season: [5, 6, 7, 8, 9, 10], time: ['dawn', 'dusk'], wind: 30, tide: 'run-in', baits: ['Ganged pilchard', 'Garfish', 'Metal slug', 'White popper'], rig: 'Gang of 3–4 × 4/0; wire or heavy mono trace (toothy)', tip: 'Chopper schools smash bait at first & last light — cast metals into the wash.' },
    { key: 'salmon', name: 'Salmon', emoji: '🐟', season: [4, 5, 6, 7, 8, 9], time: ['dawn', 'dusk', 'day'], wind: 35, tide: 'run-in', baits: ['Metal slug', 'Ganged pilchard', 'Surface popper', 'Soft plastic'], rig: '40g metal slug straight through, or ganged pillie under a float', tip: 'Look for birds working bait in the surf gutters & off the rocks.' },
    { key: 'kingfish', name: 'Kingfish', emoji: '🐋', season: [12, 1, 2, 3, 4, 5], time: ['day', 'dawn'], wind: 25, tide: 'run-in', baits: ['Live squid', 'Live yakka', 'Knife jig', 'Stickbait'], rig: 'Live-bait rig 60–80lb leader 7/0–9/0, or jig assist hooks', tip: 'Hold on reefs, headlands & channels in strong current — lock the drag, turn their head.' },
    { key: 'squid', name: 'Squid', emoji: '🦑', season: [1, 2, 3, 4, 9, 10, 11, 12], time: ['dawn', 'dusk', 'day'], wind: 22, tide: 'run-in', baits: ['Size 2.5–3.5 squid jig (prawn pattern)', 'Whitebait under float'], rig: 'Egi squid jig on 6–10lb leader; slow rip-and-pause over weed', tip: 'Fish clear water over seagrass/sand edges, best in low light on a building tide.' },
    { key: 'trevally', name: 'Trevally', emoji: '🐟', season: [12, 1, 2, 3, 4, 5], time: ['dawn', 'dusk', 'day'], wind: 28, tide: 'run-in', baits: ['Raw prawns', 'Peeled prawn', 'Cut pilchard', 'Soft plastic', 'Small blade'], rig: 'Light running sinker or unweighted, 8–12lb leader, #1–1/0', tip: 'Berley deep estuary holes & jetty pylons on a building tide — hard pullers.' },
    { key: 'luderick', name: 'Luderick', emoji: '🐟', season: [3, 4, 5, 6, 7, 8, 9], time: ['day', 'dawn'], wind: 25, tide: 'run-in', baits: ['Green weed', 'Cabbage weed'], rig: 'Float rig, light running float, #8–10 sneck, weed bait', tip: 'Trot weed under a float along walls, channels & washes on a moving tide.' }
  ];
  function timeBucket(ctx) { return ctx.isDawnDusk ? (ctx.hour < (ctx.sunriseH + 2) ? 'dawn' : 'dusk') : (ctx.isDay ? 'day' : 'night'); }
  function rank(ctx) {
    const month = ctx.month, tb = timeBucket(ctx);
    return DB.map(sp => {
      let pr = 0.30;
      if (sp.season.includes(month)) pr += 0.26; else pr -= 0.10;
      if (sp.time.includes(tb)) pr += 0.16;
      if (ctx.isDawnDusk && (sp.time.includes('dawn') || sp.time.includes('dusk'))) pr += 0.06;
      if (ctx.wind <= sp.wind) pr += 0.12; else pr -= Math.min(0.22, (ctx.wind - sp.wind) / 120);
      if (sp.tide === (ctx.tideState || '').toLowerCase() || (sp.tide === 'run-in' && ctx.tideDir === 'rising') || (sp.tide === 'run-out' && ctx.tideDir === 'falling') || (sp.tide === 'tide-change' && (ctx.tideState === 'High' || ctx.tideState === 'Low'))) pr += 0.10;
      if ((sp.key === 'mulloway' || sp.key === 'snapper') && (ctx.moonPhase === 'New Moon' || ctx.moonPhase === 'Full Moon')) pr += 0.07;
      pr += (ctx.score - 50) / 360; pr = Util.clamp(pr, 0.04, 0.97);
      return Object.assign({}, sp, { prob: Math.round(pr * 100), timeBucket: tb });
    }).sort((a, b) => b.prob - a.prob);
  }
  function get(key) { return DB.find(s => s.key === key) || null; }
  return { DB, rank, get, timeBucket };
})();

/* ---------------- AdviceEngine (Aussie advice) ---------------- */
const AdviceEngine = (() => {
  function advise(ctx, sp) {
    const baits = sp.baits.slice(0, 3);
    const tideStage = sp.tide === 'run-in' ? 'the run-in (building) tide' : sp.tide === 'run-out' ? 'the run-out (falling) tide' : sp.tide === 'tide-change' ? 'the slack either side of the tide change' : 'a moving tide';
    const time = sp.time.includes('night') ? 'after dark / low light' : sp.time.includes('dawn') ? 'dawn & dusk' : 'through the day';
    let wind = '';
    if (ctx.wind > sp.wind + 8) wind = 'Wind (' + Util.round(ctx.wind) + ' km/h) is above ' + sp.name + "'s comfort — find a sheltered bank or lee shore.";
    else if (ctx.wind > sp.wind) wind = 'Wind is on the edge for ' + sp.name + ' — heavier sinker, fish with the wind at your back.';
    else wind = 'Wind is workable for ' + sp.name + '.';
    const locType = ['bream', 'flathead', 'whiting', 'trevally', 'luderick', 'squid'].includes(sp.key) ? 'estuary flats, walls & structure' : ['tailor', 'salmon', 'mulloway'].includes(sp.key) ? 'surf gutters, headlands & breakwalls' : 'reefs, headlands & deep channels';
    const summary = 'For ' + sp.name + ': fish ' + tideStage + ', ' + time + ', around ' + locType + '. ' + (ctx.score >= 65 ? 'Conditions look good — send it.' : ctx.score >= 45 ? 'Fair — worth a go if you can get out.' : 'Tough window — short session or wait for a better tide/light.');
    return { species: sp.name, baits, rig: sp.rig, tideStage, time, locType, wind, tip: sp.tip, summary };
  }
  return { advise };
})();

/* ---------------- CalibrationService (opt-in catch-data flywheel) ----------------
   Personal, on-device, bounded, explainable. Learns which condition buckets actually
   produce catches FOR THIS USER and nudges the score (±12 pts max) with Bayesian shrinkage
   so small samples barely move it. No backend, no upload — purely local calibration.
   Honest limit: it's PERSONAL data (one log), so it's weak/slow and only reflects you. */
const CalibrationService = (() => {
  const DIMS = ['tide', 'wind', 'light', 'moon', 'pressure'];
  const BUCKETS = { tide: ['run-in', 'run-out', 'change'], wind: ['light', 'moderate', 'fresh', 'strong'], light: ['lowlight', 'day', 'night'], moon: ['newfull', 'other'], pressure: ['falling', 'steady', 'rising'] };
  const LABEL = { tide: 'tide', wind: 'wind', light: 'light', moon: 'moon', pressure: 'barometer' };
  const on = () => CacheService.get('calib_on', false) === true;
  const setOn = v => CacheService.set('calib_on', !!v);
  function vectorFrom(c) {
    return {
      tide: c.tideDir === 'rising' ? 'run-in' : c.tideDir === 'falling' ? 'run-out' : 'change',
      wind: c.wind < 12 ? 'light' : c.wind < 22 ? 'moderate' : c.wind < 32 ? 'fresh' : 'strong',
      light: c.isDawnDusk ? 'lowlight' : (c.isDay ? 'day' : 'night'),
      moon: (c.moonPhase === 'New Moon' || c.moonPhase === 'Full Moon') ? 'newfull' : 'other',
      pressure: c.pressTrend || 'steady'
    };
  }
  function counts() {
    const tally = {}; DIMS.forEach(d => { tally[d] = {}; BUCKETS[d].forEach(b => tally[d][b] = 0); });
    let n = 0;
    CatchLogService.get().forEach(c => { if (c.cond && !c.blank) { n++; DIMS.forEach(d => { const b = c.cond[d]; if (b != null && tally[d][b] != null) tally[d][b]++; }); } });
    return { tally, n };
  }
  // Bayesian-shrunk per-dimension lift → bounded points + the top contributing reasons.
  function adjust(vec) {
    const { tally, n } = counts(); if (n < 8) return { points: 0, n, reasons: [] };
    const K = 6, conf = n / (n + K); let pts = 0; const rs = [];
    DIMS.forEach(d => {
      const nb = BUCKETS[d].length, obs = tally[d][vec[d]] || 0, expected = n / nb;
      const lift = (obs + K / nb) / (expected + K / nb);
      const contrib = Math.max(-3, Math.min(3, (lift - 1) * 6 * conf));
      pts += contrib; rs.push({ d, bucket: vec[d], obs, n, contrib });
    });
    pts = Math.max(-12, Math.min(12, Math.round(pts)));
    const reasons = rs.filter(r => Math.abs(r.contrib) >= 0.8).sort((a, b) => Math.abs(b.contrib) - Math.abs(a.contrib)).slice(0, 2)
      .map(r => [(r.contrib > 0 ? '↑ ' : '↓ ') + 'You catch ' + (r.contrib > 0 ? 'more' : 'fewer') + ' on “' + r.bucket + '” ' + LABEL[r.d] + ' (' + r.obs + '/' + r.n + ' logged)', r.contrib > 0 ? 'good' : 'warn']);
    return { points: pts, n, reasons };
  }
  return { on, setOn, vectorFrom, adjust, counts, DIMS, BUCKETS };
})();

/* ---------------- ScoreEngine ---------------- */
const ScoreEngine = (() => {
  const word = s => s >= 80 ? 'SEND IT 🚀' : s >= 65 ? 'Worth a crack' : s >= 45 ? 'Fair — give it a go' : s >= 28 ? 'Slow — tough going' : 'Leave it — tie rigs at home';
  const color = s => s >= 70 ? 'var(--good)' : s >= 45 ? 'var(--warn)' : 'var(--bad)';
  function nearestHour(times, now) { let best = 0, bd = Infinity; for (let i = 0; i < times.length; i++) { const dd = Math.abs(new Date(times[i]) - now); if (dd < bd) { bd = dd; best = i; } } return best; }
  function compute(p) {
    // p: {now,lat,lon,weather(normalised f),tide,moon,sol,swell,weatherKnown}
    const f = p.weather, C0 = (f && f.current) || {};
    const cur = { temperature_2m: Util.num(C0.temperature_2m, 18), apparent_temperature: Util.num(C0.apparent_temperature, Util.num(C0.temperature_2m, 18)), relative_humidity_2m: Util.num(C0.relative_humidity_2m, 60), is_day: C0.is_day == null ? 1 : C0.is_day, precipitation: Util.num(C0.precipitation, 0), cloud_cover: Util.num(C0.cloud_cover, null), weather_code: Util.num(C0.weather_code, 2), surface_pressure: Util.num(C0.surface_pressure, 1015), wind_speed_10m: Util.num(C0.wind_speed_10m, 0), wind_direction_10m: Util.num(C0.wind_direction_10m, 0), wind_gusts_10m: Util.num(C0.wind_gusts_10m, Util.num(C0.wind_speed_10m, 0)) };
    const now = p.now, month = now.getMonth() + 1, hour = now.getHours() + now.getMinutes() / 60;
    const sr = new Date(f.daily.sunrise[0]), ss = new Date(f.daily.sunset[0]);
    const srH = sr.getHours() + sr.getMinutes() / 60, ssH = ss.getHours() + ss.getMinutes() / 60;
    const isDawnDusk = Math.abs(hour - srH) < 1.25 || Math.abs(hour - ssH) < 1.25;
    const wave = p.swell ? p.swell.wave_height : null;
    let pressTrend = 'steady', pTrendVal = 0;
    try { const i = nearestHour(f.hourly.time, now), p0 = f.hourly.surface_pressure[i], p3 = f.hourly.surface_pressure[Math.min(i + 3, f.hourly.surface_pressure.length - 1)]; pTrendVal = p3 - p0; pressTrend = pTrendVal > 1.2 ? 'rising' : (pTrendVal < -1.2 ? 'falling' : 'steady'); } catch (_) { }
    const solScore = SolunarService.strength(now.getTime(), p.sol);
    const reasons = []; let score = 50;
    score += (solScore - 0.5) * 44;
    if (solScore > 0.66) reasons.push(['Inside a solunar peak — fish feed harder', 'good']);
    else if (solScore < 0.25) reasons.push(['Outside the solunar windows right now', 'bad']);
    if (isDawnDusk) { score += 10; reasons.push(['Low-light window (dawn/dusk) — prime feeding', 'good']); }
    const w = cur.wind_speed_10m;
    if (w < 6) { score += 2; reasons.push(['Light wind — easy casting', 'good']); }
    else if (w <= 22) { score += 8; reasons.push(['Workable wind (' + Util.round(w) + ' km/h)', 'good']); }
    else if (w <= 32) { score -= 6; reasons.push(['Fresh wind (' + Util.round(w) + ' km/h) — find shelter', 'warn']); }
    else { score -= 18; reasons.push(['Strong wind (' + Util.round(w) + ' km/h) — tough & risky', 'bad']); }
    if (pressTrend === 'falling') { score += 8; reasons.push(['Falling barometer ahead of a change — fires the bite', 'good']); }
    else if (pressTrend === 'rising' && cur.surface_pressure > 1023) { score -= 5; reasons.push(['High & rising pressure — bluebird, slower bite', 'warn']); }
    if (p.moon.phase === 'New Moon' || p.moon.phase === 'Full Moon') { score += 7; reasons.push([p.moon.phase + ' — strong tides & night bite', 'good']); }
    const wc = cur.weather_code;
    if ([95, 96, 99, 82].includes(wc)) { score -= 16; reasons.push(['Storms about — dangerous & puts fish down', 'bad']); }
    else if ([65, 67, 75, 86].includes(wc)) { score -= 8; reasons.push(['Heavy rain about', 'warn']); }
    else if ([1, 2, 3, 45, 51, 53, 61, 80].includes(wc)) { score += 4; reasons.push(['Cloud cover — fish hold up in the water column', 'good']); }
    if (wave != null) { if (wave <= 1.2) { score += 4; } else if (wave <= 2) { } else if (wave <= 3) { score -= 8; reasons.push(['Big swell (' + Util.round(wave, 1) + ' m)', 'warn']); } else { score -= 16; reasons.push(['Dangerous swell (' + Util.round(wave, 1) + ' m)', 'bad']); } }
    score = Math.round(Util.clamp(score, 3, 99));
    // Species mode: blend in the selected species' probability
    let speciesBias = null;
    if (p.speciesKey && p.speciesKey !== 'auto') {
      const ctx0 = { month, hour, isDawnDusk, isDay: cur.is_day, sunriseH: srH, wind: w, tideState: p.tide.state, tideDir: p.tide.dir, moonPhase: p.moon.phase, score };
      const ranked = SpeciesEngine.rank(ctx0), me = ranked.find(s => s.key === p.speciesKey);
      if (me) { speciesBias = me.prob; score = Math.round(Util.clamp(score * 0.6 + me.prob * 0.4, 3, 99)); reasons.unshift(['Tuned for ' + me.name + ' (' + me.prob + '% likely now)', me.prob >= 55 ? 'good' : me.prob >= 35 ? 'warn' : 'bad']); }
    }
    // Catch-data flywheel (opt-in): personal, bounded, explainable calibration from the user's log
    let calib = null;
    if (CalibrationService.on()) {
      const vec = CalibrationService.vectorFrom({ tideDir: p.tide.dir, tideState: p.tide.state, wind: w, isDawnDusk, isDay: cur.is_day, moonPhase: p.moon.phase, pressTrend });
      calib = CalibrationService.adjust(vec);
      if (calib.points) {
        score = Math.round(Util.clamp(score + calib.points, 3, 99));
        reasons.push([(calib.points > 0 ? '+' : '') + calib.points + ' tuned from your catch log (' + calib.n + ' logged)', calib.points > 0 ? 'good' : 'warn']);
        calib.reasons.forEach(r => reasons.push(r));
      }
    }
    // Safety warnings
    const warnings = [];
    if (w >= 35 || cur.wind_gusts_10m >= 45) warnings.push(['danger', 'Strong wind ' + Util.round(w) + ' km/h (gusts ' + Util.round(cur.wind_gusts_10m) + '). Small boats stay in; rock fishing is dangerous.']);
    else if (w >= 25) warnings.push(['warn', 'Fresh breeze ' + Util.round(w) + ' km/h — chop building, secure gear, mind exposed ledges.']);
    if (wave != null && wave >= 3) warnings.push(['danger', 'Hazardous swell ' + Util.round(wave, 1) + ' m. Do NOT rock/platform fish; strong rips on beaches.']);
    else if (wave != null && wave >= 2) warnings.push(['warn', 'Swell ' + Util.round(wave, 1) + ' m — caution on low ledges, watch surprise sets.']);
    if ([95, 96, 99, 82].includes(wc)) warnings.push(['danger', 'Thunderstorm risk — lightning. Get off the water, away from graphite rods.']);
    if (f.daily.uv_index_max && f.daily.uv_index_max[0] >= 8 && cur.is_day) warnings.push(['warn', 'Extreme UV ' + Util.round(f.daily.uv_index_max[0]) + ' — hat, long sleeves, SPF50+.']);
    if (p.swell && p.swell.sea_surface_temperature != null && p.swell.sea_surface_temperature < 16) warnings.push(['warn', 'Cold water ' + Util.round(p.swell.sea_surface_temperature, 1) + '°C — wear a PFD; hypothermia risk if you go in.']);
    if (!p.weatherKnown) warnings.push(['warn', 'Low data confidence — running on the offline estimate. Re-check when you have signal.']);
    warnings.push(['info', 'Tell someone your plan. Wear a lifejacket on rocks & in boats. Never turn your back on the sea.']);
    // Confidence rating
    let confidence = 'High', confWhy = 'Live weather + live tide';
    if (!p.weatherKnown) { confidence = 'Low'; confWhy = 'No live weather — offline estimate'; }
    else if (!p.tide.real) { confidence = 'Medium'; confWhy = p.tide.method === 'fitted' ? 'Live weather, tide fitted to live data' : 'Live weather, modelled tide'; }
    else if (p.stale) { confidence = 'Medium'; confWhy = 'Showing cached data'; }
    return {
      score, label: word(score), color: color(score), confidence, confWhy,
      reasons, warnings, speciesBias, calib,
      inputs: { base: 50, solScore: Util.round(solScore, 3), isDawnDusk, wind: Util.round(w, 1), pressTrend, wave, weatherKnown: p.weatherKnown !== false },
      cur, isDawnDusk, sunrise: sr.getTime(), sunset: ss.getTime(), pressTrend, pTrendVal, wave,
      waterTemp: p.swell ? p.swell.sea_surface_temperature : null, wavePeriod: p.swell ? p.swell.wave_period : null
    };
  }
  return { compute, word, color };
})();

/* ---------------- FavoritesService + Recent + CatchLog ---------------- */
const FavoritesService = (() => {
  const get = () => CacheService.get('saved', []);
  const set = v => CacheService.set('saved', v);
  const near = (a, b) => Math.abs(a.lat - b.lat) < 0.02 && Math.abs(a.lon - b.lon) < 0.02;
  function isSaved(loc) { return loc && get().some(s => near(s, loc)); }
  function toggle(loc) { let s = get(); if (isSaved(loc)) { s = s.filter(x => !near(x, loc)); } else { s.unshift({ name: loc.name, lat: loc.lat, lon: loc.lon }); s = s.slice(0, 12); } set(s); return isSaved(loc); }
  const recents = () => CacheService.get('recent', []);
  function pushRecent(loc) { if (!loc) return; let r = recents().filter(x => !near(x, loc)); r.unshift({ name: loc.name, lat: loc.lat, lon: loc.lon }); CacheService.set('recent', r.slice(0, 8)); }
  return { get, set, isSaved, toggle, recents, pushRecent };
})();
const CatchLogService = (() => {
  const get = () => CacheService.get('log', []);
  const set = v => CacheService.set('log', v);
  function add(c) { const l = get(); l.push(c); set(l); }
  function del(id) { set(get().filter(c => c.id !== id)); }
  return { get, set, add, del };
})();

/* ---------------- LocationService + orchestration ---------------- */
const LocationService = (() => {
  const DEFAULT = { name: 'Sydney, NSW', lat: -33.8688, lon: 151.2093, region: 'New South Wales', source: 'default' };
  function saveLast(loc) { CacheService.set('last', loc); }
  function getLast() { return CacheService.get('last', null); }
  async function gps() {
    if (!navigator.geolocation) { Util.toast('GPS not supported on this device'); return; }
    Util.toast('Getting your location…');
    navigator.geolocation.getCurrentPosition(async pos => {
      const lat = pos.coords.latitude, lon = pos.coords.longitude;
      const name = await GeocodingService.reverse(lat, lon).catch(() => 'My Location');
      load({ name, lat, lon, region: '', source: 'gps' });
    }, err => { Util.toast(err.code === 1 ? 'Location permission denied' : 'Could not get a GPS fix'); }, { enableHighAccuracy: true, timeout: 9000, maximumAge: 60000 });
  }
  // Two-phase, sequence-guarded load with normalised objects.
  async function load(loc) {
    const seq = ++AppState.loadSeq;
    if (!loc.source) loc.source = 'unknown';
    AppState.loc = loc; UIService.setLocName(loc); UIService.renderFav();
    saveLast(loc); FavoritesService.pushRecent(loc); UIService.renderSavedRecent();
    DebugService.d.attempts = {};
    DebugService.record('location', { name: loc.name, lat: loc.lat, lon: loc.lon, source: loc.source });

    // instant cached render (stale)
    const cached = CacheService.getCond(loc.lat, loc.lon);
    if (cached) UIService.render(cached, true);
    else UIService.loadingHero(loc);

    // PHASE 1: weather (the only hard dependency), bounded
    const ctrl = new AbortController(); const to = setTimeout(() => ctrl.abort(), 11000);
    let w = null; try { w = await WeatherService.get(loc.lat, loc.lon, ctrl.signal); } catch (_) { } clearTimeout(to);
    if (seq !== AppState.loadSeq) return; // stale guard

    if (!w || !w.f) {
      // fallback chain: cached → last-known → engine estimate → no-data
      if (cached) { UIService.render(cached, true); UIService.flagStale('Couldn’t refresh — showing saved conditions', loc); return; }
      const last = CacheService.lastKnownCond();
      if (last) { UIService.render(last, true); UIService.flagStale('No live data here — showing last-known conditions', loc); return; }
      const est = buildData(loc, WeatherService.synth(loc.lat, loc.lon), 'Estimate (moon + tide engine)', null, false);
      UIService.render(est, false); UIService.flagStale('No live weather reached — estimated from moon, solunar & the tide engine', loc); return;
    }

    // tide: cached-live first, else engine (instant); live attempted in phase 2
    let tideCache = CacheService.getTide(loc.lat, loc.lon);
    const d1 = buildData(loc, w.f, w.src, tideCache, true);
    UIService.render(d1, false);
    CacheService.setCond(loc.lat, loc.lon, d1);

    // PHASE 2: live tide (+harmonic fit) + BoM proxy backup + swell, in background
    const ctrl2 = new AbortController(); const to2 = setTimeout(() => ctrl2.abort(), 12000);
    let live = null, swell = null;
    try { [live, swell] = await Promise.all([TideService.fetchLive(loc.lat, loc.lon, ctrl2.signal), WeatherService.swell(loc.lat, loc.lon, ctrl2.signal)]); } catch (_) { }
    if (seq !== AppState.loadSeq) { clearTimeout(to2); return; }
    // Whenever we got a usable sea-level series, fit constituents and cache them (data-driven engine).
    if (live && live.raw) { try { const f = TideService.fit(live.raw.times, live.raw.heights); if (TideService.fitValid(f)) { CacheService.setHarm(loc.lat, loc.lon, f); DebugService.record('tideFit', { n: f.n, rms: +f.rms.toFixed(3), m2: +f.m2.toFixed(3), F: +f.F.toFixed(2) }); } } catch (_) { } }
    let tideRes = tideCache, fallbackReason = null;
    if (live && live.ext && TideService.valid(live.ext)) {
      tideRes = { extrema: live.ext, source: live.source, method: 'live' }; CacheService.setTide(loc.lat, loc.lon, live.ext, live.source);
    } else {
      fallbackReason = (live && live.reason) || 'Open-Meteo Marine: no data';
      const aus = await TideService.fetchAusTides(loc.lat, loc.lon, ctrl2.signal).catch(() => null);
      if (aus && aus.ext && TideService.valid(aus.ext)) { tideRes = { extrema: aus.ext, source: aus.source, method: 'live' }; CacheService.setTide(loc.lat, loc.lon, aus.ext, aus.source); fallbackReason = null; }
      else if (aus && aus.reason) fallbackReason += ' · ' + aus.reason;
    }
    clearTimeout(to2);
    if (seq !== AppState.loadSeq) return;
    DebugService.record('tideResult', { source: tideRes ? tideRes.source : 'cold-start engine', method: tideRes ? tideRes.method : 'cold', fallbackReason, cacheKey: CacheService.key('tide', loc.lat, loc.lon), cacheHit: !!tideCache });
    const d2 = buildData(loc, w.f, w.src, tideRes, true, swell, fallbackReason);
    UIService.render(d2, false);
    CacheService.setCond(loc.lat, loc.lon, d2);
    DebugService.group('SendIt load'); DebugService.log('location', loc); DebugService.log('weather', w.src); DebugService.log('tide', d2.tide.source, d2.tide.real ? 'LIVE' : 'ENGINE'); DebugService.end();
  }
  // Assemble the full normalised data object the UI renders.
  function buildData(loc, f, weatherSrc, tideCache, weatherKnown, swell, fallbackReason) {
    const now = new Date();
    if (!f.daily || !Array.isArray(f.daily.time) || !f.daily.time.length) f = Object.assign({}, f, { daily: WeatherService.synth(loc.lat, loc.lon).daily });
    if (!f.hourly || !Array.isArray(f.hourly.time) || !f.hourly.time.length) f = Object.assign({}, f, { hourly: WeatherService.synth(loc.lat, loc.lon).hourly });
    const moon = MoonService.info(now);
    const sol = SolunarService.periods(now, loc.lat, loc.lon);
    let tide;
    if (tideCache && tideCache.extrema && TideService.valid(tideCache.extrema)) {
      const real = !/engine/i.test(tideCache.source);
      tide = TideService.build(tideCache.extrema, now, real, tideCache.source, real ? null : fallbackReason, tideCache.method || (real ? 'live' : 'cached'));
    } else {
      const ce = TideService.coldExtrema(loc.lat, loc.lon, now);
      tide = TideService.build(ce.extrema, now, false, ce.source, fallbackReason, ce.method);
    }
    const sc = ScoreEngine.compute({ now, lat: loc.lat, lon: loc.lon, weather: f, tide, moon, sol, swell: swell || null, weatherKnown, speciesKey: AppState.species, stale: false });
    // species ranking context
    const sr = new Date(f.daily.sunrise[0]);
    const ctx = { month: now.getMonth() + 1, hour: now.getHours() + now.getMinutes() / 60, isDawnDusk: sc.isDawnDusk, isDay: sc.cur.is_day, sunriseH: sr.getHours() + sr.getMinutes() / 60, wind: sc.cur.wind_speed_10m, tideState: tide.state, tideDir: tide.dir, moonPhase: moon.phase, score: sc.score };
    const species = SpeciesEngine.rank(ctx);
    // daily planner scores
    const daily = f.daily.time.map((t, i) => {
      const wsd = f.daily.wind_speed_10m_max[i], code = f.daily.weather_code[i]; let ds = 55;
      if (wsd <= 22) ds += 10; else if (wsd <= 32) ds -= 6; else ds -= 18;
      if ([95, 96, 99, 82].includes(code)) ds -= 16; else if ([0, 1, 2, 3].includes(code)) ds += 6;
      if (f.daily.precipitation_probability_max[i] > 70) ds -= 6;
      const dM = MoonService.info(new Date(t + 'T12:00:00')); if (dM.phase === 'New Moon' || dM.phase === 'Full Moon') ds += 6;
      ds = Math.round(Util.clamp(ds, 5, 98));
      return { date: new Date(t + 'T00:00:00'), code, ds, tmax: f.daily.temperature_2m_max[i], tmin: f.daily.temperature_2m_min[i], wind: wsd, gust: f.daily.wind_gusts_10m_max[i], windDir: f.daily.wind_direction_10m_dominant[i], rainP: f.daily.precipitation_probability_max[i], uv: f.daily.uv_index_max ? f.daily.uv_index_max[i] : null, sunrise: new Date(f.daily.sunrise[i]), sunset: new Date(f.daily.sunset[i]), moon: dM };
    });
    // 7-day solunar windows so the Bite Window Timeline (Tomorrow / This week) is populated
    const solWeek = { majors: [], minors: [] };
    for (let i = 0; i < 7; i++) { const dd = new Date(now.getTime() + i * 86400000); const pp = SolunarService.periods(dd, loc.lat, loc.lon); solWeek.majors.push(...pp.majors); solWeek.minors.push(...pp.minors); }
    return { loc, now: now.getTime(), fetchedAt: Date.now(), weatherSrc, weatherKnown, moon, sol, solWeek, tide, score: sc, species, daily, hourly: f.hourly, cur: sc.cur, swell: swell || null };
  }
  return { DEFAULT, load, gps, getLast, buildData };
})();

/* ---------------- UIService ---------------- */
const UIService = (() => {
  const wmo = WeatherService.wmo;
  function setLocName(loc) { $('#locName').textContent = loc.name; }
  function loadingHero(loc) { $('#scoreNum').textContent = '–'; $('#scoreWord').textContent = 'Loading ' + loc.name + '…'; $('#scoreSub').textContent = 'Pulling live marine data'; $('#updated').textContent = 'Loading…'; }
  function flagStale(msg, loc) { Util.toast(msg, 3200); }
  function renderFav() { const ic = $('#favIc'); const on = FavoritesService.isSaved(AppState.loc); ic.setAttribute('fill', on ? 'var(--sand)' : 'none'); ic.style.color = on ? 'var(--sand)' : 'currentColor'; }
  function srcBadge(kind, label) { return '<span class="src ' + kind + '">' + Util.esc(label) + '</span>'; }

  function render(d, stale) {
    AppState.data = d; d.score.stale = stale;
    const now = new Date(d.now), sc = d.score;
    $('#updated').textContent = (stale ? 'Saved ' : 'Updated ') + Util.ago(d.fetchedAt);
    // ring + word
    const C = 2 * Math.PI * 52, arc = $('#ringArc');
    arc.style.strokeDasharray = C; arc.style.strokeDashoffset = C * (1 - sc.score / 100); arc.style.stroke = sc.color;
    $('#scoreNum').textContent = sc.score; $('#scoreNum').style.color = sc.color;
    $('#scoreWord').textContent = (d.weatherKnown ? '' : 'Estimate — ') + sc.label;
    $('#scoreSub').textContent = seasonName(now.getMonth() + 1) + ' · ' + Util.fmtTime(now) + ' · ' + (d.weatherKnown ? (d.cur.is_day ? 'daylight' : 'after dark') : 'moon + tide only');
    const cc = sc.confidence === 'High' ? 'good' : sc.confidence === 'Medium' ? 'warn' : 'bad';
    $('#confBadge').innerHTML = '<span class="chip ' + cc + '" style="margin-top:8px"><svg class="ic" style="width:13px;height:13px" viewBox="0 0 24 24"><path d="M12 2l3 7h7l-5.5 4 2 7-6.5-4.5L6 22l2-7L2.5 9H9z"/></svg>' + sc.confidence + ' confidence · ' + Util.esc(sc.confWhy) + '</span>';
    // data source chips
    $('#dataSrc').innerHTML =
      srcBadge(d.weatherKnown ? 'live' : 'est', 'Weather: ' + (d.weatherKnown ? (d.weatherSrc || 'live').replace(' (backup)', '') : 'estimate')) +
      srcBadge(d.tide.real ? 'live' : 'engine', 'Tide: ' + (d.tide.real ? d.tide.source.replace(' (cached)', '') : 'on-device engine')) +
      srcBadge(d.swell ? 'live' : 'off', 'Swell: ' + (d.swell ? 'live' : 'n/a'));

    renderBestWindow(d);
    renderBite(d);
    renderWhy(d);
    renderTide(d);
    renderWeather(d);
    renderSpecies(d);
    renderPlanner(d);
    renderSafety(d);
  }

  function allWindows(d) {
    const wins = [];
    const sol = d.solWeek || d.sol;
    [...sol.majors, ...sol.minors].forEach(p => wins.push({ kind: p.label, t: p.t, len: p.len, w: p.label === 'Major' ? 1 : 0.6 }));
    // dawn & dusk per day across the 7-day forecast
    (d.daily || []).forEach(day => {
      if (day.sunrise) wins.push({ kind: 'Dawn', t: new Date(day.sunrise).getTime(), len: 90, w: 0.9 });
      if (day.sunset) wins.push({ kind: 'Dusk', t: new Date(day.sunset).getTime(), len: 90, w: 0.9 });
    });
    return wins.filter(x => x.t).sort((a, b) => a.t - b.t);
  }
  function renderBestWindow(d) {
    const cand = allWindows(d).filter(x => x.t + x.len * 60000 >= d.now).sort((a, b) => (b.w - a.w) || (a.t - b.t));
    const best = cand[0];
    if (best) { const a = new Date(best.t), b = new Date(best.t + best.len * 60000); $('#bestWindow').textContent = '⭐ Best bite window: ' + Util.fmtTime(a) + '–' + Util.fmtTime(b) + ' · ' + best.kind; }
    else $('#bestWindow').textContent = '';
  }
  function renderBite(d) {
    const tabs = ['Today', 'Tomorrow', 'This week'];
    $('#biteTabs').innerHTML = tabs.map((t, i) => '<button class="chip ' + (i === AppState.biteTab ? 'good' : '') + '" data-bt="' + i + '">' + t + '</button>').join('');
    $$('#biteTabs [data-bt]').forEach(b => b.addEventListener('click', () => { AppState.biteTab = +b.dataset.bt; renderBite(d); }));
    const sod = new Date(d.now); sod.setHours(0, 0, 0, 0);
    let lo = sod.getTime(), hi;
    if (AppState.biteTab === 0) hi = lo + 86400000;
    else if (AppState.biteTab === 1) { lo += 86400000; hi = lo + 86400000; }
    else { hi = lo + 7 * 86400000; }
    let wins = allWindows(d).filter(x => x.t >= lo && x.t < hi);
    // dedupe by 30-min bucket+kind
    const seen = {}; wins = wins.filter(x => { const k = x.kind + Math.round(x.t / 1800000); if (seen[k]) return false; seen[k] = 1; return true; });
    wins.sort((a, b) => (b.w - a.w) || (a.t - b.t)); wins = wins.slice(0, 8).sort((a, b) => a.t - b.t);
    const nowMs = d.now;
    if (!wins.length) { $('#biteList').innerHTML = '<div class="muted" style="font-size:13px">No standout windows in this range.</div>'; return; }
    $('#biteList').innerHTML = wins.map(p => {
      const end = p.t + p.len * 60000, active = nowMs >= p.t - p.len * 30000 && nowMs <= end;
      const icon = p.kind === 'Major' ? '⭐' : p.kind === 'Minor' ? '✨' : '☀️';
      const day = new Date(p.t), dl = sameDay(day, new Date(nowMs)) ? '' : ' · ' + day.toLocaleDateString('en-AU', { weekday: 'short' });
      return '<div class="tideRow"><span style="font-size:16px;width:22px">' + icon + '</span><div style="flex:1"><div style="font-weight:700">' + p.kind + (active ? ' · <span style="color:var(--good)">NOW</span>' : '') + '<span class="muted" style="font-weight:500;font-size:12px">' + dl + '</span></div><div class="muted" style="font-size:12px">' + Util.fmtTime(p.t) + ' – ' + Util.fmtTime(end) + '</div></div></div>';
    }).join('');
  }
  function renderWhy(d) {
    const r = d.score.reasons;
    $('#whyList').innerHTML = (r.length ? r : [['Neutral conditions', 'warn']]).map(([t, k]) => {
      const col = k === 'good' ? 'var(--good)' : k === 'bad' ? 'var(--bad)' : 'var(--warn)';
      const sign = k === 'good' ? '+' : k === 'bad' ? '−' : '•';
      return '<div class="row" style="padding:7px 0;border-bottom:1px solid var(--line)"><span style="color:' + col + ';font-weight:800;width:16px">' + sign + '</span><span style="font-size:13.5px">' + Util.esc(t) + '</span></div>';
    }).join('');
  }
  function renderTide(d) {
    const t = d.tide, fh = v => (v >= 0 ? '+' : '') + v.toFixed(2) + ' m';
    const m = t.method || (t.real ? 'live' : 'generic');
    const kind = m === 'live' ? (/cached/i.test(t.source) ? 'cache' : 'live') : m === 'cached' ? 'cache' : m === 'fitted' ? 'cache' : 'engine';
    const label = /cached/i.test(t.source) ? 'Cached' : m === 'live' ? 'Live' : m === 'fitted' ? 'Fitted' : 'Engine';
    $('#tideSrc').className = 'src ' + kind;
    $('#tideSrc').textContent = label;
    const future = [t.nextHigh, t.nextLow].filter(Boolean).sort((a, b) => a.t - b.t), nxt = future[0] || t.next;
    const mins = nxt ? Math.round((nxt.t - d.now) / 60000) : null;
    const cd = (mins != null && mins > 0) ? (mins >= 60 ? Math.floor(mins / 60) + 'h ' + (mins % 60) + 'm' : mins + 'm') : '';
    $('#tideNowNext').innerHTML =
      '<div class="tile"><div class="k">Now</div><div class="v" style="font-size:18px">' + Util.esc(t.state) + (t.curHeight != null ? ' <small>' + fh(t.curHeight) + '</small>' : '') + '</div></div>' +
      '<div class="tile"><div class="k">Next</div><div class="v" style="font-size:18px">' + (nxt ? (Util.esc(nxt.type || t.nextType) + ' ' + Util.fmtTime(nxt.t)) : '—') + '</div>' + (cd ? '<div class="x">in ' + cd + '</div>' : '') + '</div>';
    drawTideChart(d);
    // range toggle 48h/7d
    $('#tideRange').innerHTML = ['48 h', '7 day'].map((l, i) => '<button class="chip ' + ((AppState._tideRange || 0) === i ? 'good' : '') + '" data-tr="' + i + '">' + l + '</button>').join('');
    $$('#tideRange [data-tr]').forEach(b => b.addEventListener('click', () => { AppState._tideRange = +b.dataset.tr; renderTide(d); }));
    const horizon = (AppState._tideRange || 0) === 1 ? 7 * 86400000 : 48 * 3600000;
    const evAll = ((AppState._tideRange || 0) === 1 ? t.events7d : t.events48) || [];
    const ev = evAll.filter(e => e.t >= d.now - 40 * 60000 && e.t <= d.now + horizon).sort((a, b) => a.t - b.t);
    const todayKey = new Date(d.now).toDateString(), tomKey = new Date(d.now + 86400000).toDateString();
    const groups = {}, order = []; ev.forEach(e => { const k = new Date(e.t).toDateString(); if (!groups[k]) { groups[k] = []; order.push(k); } groups[k].push(e); });
    $('#tideTable').innerHTML = order.map(k => {
      const lbl = k === todayKey ? 'Today' : k === tomKey ? 'Tomorrow' : new Date(k).toLocaleDateString('en-AU', { weekday: 'long' });
      const dstr = new Date(k).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' });
      const rows = groups[k].map(e => { const up = e.type === 'High'; return '<div class="tideRow" style="padding:6px 0;border-bottom:1px solid var(--line)"><span style="width:50px;color:' + (up ? 'var(--good)' : 'var(--warn)') + ';font-weight:700">' + (up ? '▲ High' : '▼ Low') + '</span><span class="t">' + Util.fmtTime(e.t) + '</span><span class="h">' + (e.h >= 0 ? '+' : '') + e.h.toFixed(2) + ' m</span></div>'; }).join('');
      return '<div class="daycard"><div class="hd"><span>' + lbl + ' <span class="muted" style="font-weight:500">' + dstr + '</span></span></div>' + rows + '</div>';
    }).join('') || '<div class="muted" style="font-size:13px">Tide times unavailable.</div>';
    $('#tideNote').textContent = t.real ? ('Source: ' + t.source.replace(' (cached)', '') + '. Heights rel. mean sea level.') : (t.method === 'fitted' ? ('Tide fitted to recent live data (harmonic analysis, works offline) — ' + (t.source || '') + '. Heights rel. MSL.') : ('Modelled tide (on-device harmonic engine, regional) — estimate. ')) + ' Check the Bureau of Meteorology before any low-tide rock/breakwall session.';
  }
  function drawTideChart(d) {
    const cv = $('#tideChart'); if (!cv) return; const ctx = cv.getContext('2d'), dpr = window.devicePixelRatio || 1;
    const W = cv.width = cv.clientWidth * dpr, H = cv.height = 130 * dpr; ctx.clearRect(0, 0, W, H);
    const pts = TideService.series(d.tide.extrema, new Date(d.now), 48); if (pts.length < 2) return;
    const t0 = pts[0].t, t1 = pts[pts.length - 1].t, span = (t1 - t0) || 1;
    const hs = pts.map(p => p.h), mn = Math.min(...hs), mx = Math.max(...hs), rng = (mx - mn) || 1;
    const padX = 8 * dpr, padTop = 12 * dpr, padBot = 18 * dpr;
    const X = t => padX + (W - 2 * padX) * (t - t0) / span, Y = h => padTop + (H - padTop - padBot) * (1 - (h - mn) / rng);
    const line = getComputedStyle(document.documentElement).getPropertyValue('--line').trim() || '#1c3a52';
    const muted = getComputedStyle(document.documentElement).getPropertyValue('--muted').trim() || '#8aa4b8';
    ctx.font = (10 * dpr) + 'px system-ui';
    for (let i = 0; i < pts.length; i++) { const dt = new Date(pts[i].t); if (dt.getHours() === 0) { const x = X(pts[i].t); ctx.strokeStyle = line; ctx.lineWidth = dpr; ctx.beginPath(); ctx.moveTo(x, padTop); ctx.lineTo(x, H - padBot); ctx.stroke(); ctx.fillStyle = muted; ctx.fillText(dt.toLocaleDateString('en-AU', { weekday: 'short' }), x + 3 * dpr, H - 6 * dpr); } }
    ctx.beginPath(); pts.forEach((p, i) => { const x = X(p.t), y = Y(p.h); i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }); ctx.lineTo(X(t1), H - padBot); ctx.lineTo(X(t0), H - padBot); ctx.closePath();
    const grad = ctx.createLinearGradient(0, padTop, 0, H - padBot); grad.addColorStop(0, 'rgba(43,212,212,.28)'); grad.addColorStop(1, 'rgba(43,212,212,0)'); ctx.fillStyle = grad; ctx.fill();
    ctx.beginPath(); pts.forEach((p, i) => { const x = X(p.t), y = Y(p.h); i ? ctx.lineTo(x, y) : ctx.moveTo(x, y); }); ctx.strokeStyle = '#2bd4d4'; ctx.lineWidth = 2 * dpr; ctx.stroke();
    const nx = X(d.now); ctx.strokeStyle = '#33e1c0'; ctx.setLineDash([4 * dpr, 3 * dpr]); ctx.beginPath(); ctx.moveTo(nx, padTop); ctx.lineTo(nx, H - padBot); ctx.stroke(); ctx.setLineDash([]);
    ctx.fillStyle = '#33e1c0'; ctx.fillText('now', nx + 2 * dpr, 10 * dpr);
    (d.tide.events48 || []).forEach(e => { if (e.t < t0 || e.t > t1) return; const x = X(e.t), y = Y(e.h); ctx.fillStyle = e.type === 'High' ? '#33e1c0' : '#f4b740'; ctx.beginPath(); ctx.arc(x, y, 3 * dpr, 0, 7); ctx.fill(); });
  }
  function renderWeather(d) {
    const c = d.cur, [desc, em] = wmo(c.weather_code), known = d.weatherKnown;
    $('#wxTiles').innerHTML =
      tile('Wind', known ? windDisp(c.wind_speed_10m) : '—', windUnit(), known ? (Util.compass(c.wind_direction_10m) + ' · gust ' + windDisp(c.wind_gusts_10m)) : 'no live wind') +
      tile('Weather', known ? Util.round(c.temperature_2m) : '—', '°C', known ? (em + ' ' + desc + ' · feels ' + Util.round(c.apparent_temperature) + '°') : 'no live weather') +
      tile('Swell', d.swell && d.swell.wave_height != null ? Util.round(d.swell.wave_height, 1) : '—', 'm', d.swell && d.swell.wave_period != null ? ('period ' + Util.round(d.swell.wave_period) + 's') : 'no marine data here') +
      tile('Moon', d.moon.illumPct, '%', d.moon.emoji + ' ' + d.moon.phase);
    $('#wxExtra').innerHTML =
      mini('Pressure', Util.round(c.surface_pressure) + ' hPa', d.score.pressTrend + (d.score.pTrendVal ? ' ' + (d.score.pTrendVal > 0 ? '+' : '') + Util.round(d.score.pTrendVal, 1) : '')) +
      mini('Water', d.score.waterTemp != null ? Util.round(d.score.waterTemp, 1) + '°C' : '—', 'UV ' + (d.daily[0].uv != null ? Util.round(d.daily[0].uv) : '—')) +
      mini('Cloud', c.cloud_cover != null ? Util.round(c.cloud_cover) + '%' : '—', 'rain ' + Util.round(d.daily[0].rainP) + '%');
  }
  function tile(k, v, unit, x) { return '<div class="tile"><div class="k">' + k + '</div><div class="v">' + v + ' <small>' + unit + '</small></div><div class="x">' + Util.esc(x) + '</div></div>'; }
  function mini(k, v, x) { return '<div class="tile" style="text-align:center"><div class="k">' + k + '</div><div class="v" style="font-size:16px">' + Util.esc(v) + '</div><div class="x">' + Util.esc(x) + '</div></div>'; }
  function renderSpecies(d) {
    const sel = AppState.species;
    const chips = [{ key: 'auto', name: 'Auto' }].concat(SpeciesEngine.DB);
    $('#specBar').innerHTML = chips.map(s => '<button class="' + (sel === s.key ? 'on' : '') + '" data-sp="' + s.key + '">' + (s.emoji ? s.emoji + ' ' : '') + s.name + '</button>').join('');
    $$('#specBar [data-sp]').forEach(b => b.addEventListener('click', () => { AppState.species = b.dataset.sp; if (AppState.loc) LocationService.load(AppState.loc); }));
    let html = '';
    if (sel === 'auto') {
      const top = d.species.slice(0, 4);
      html = top.map(s => speciesRow(s)).join('');
      const adv = AdviceEngine.advise({ wind: d.cur.wind_speed_10m, score: d.score.score }, SpeciesEngine.get(top[0].key));
      html += adviceBox(adv, top[0]);
    } else {
      const sp = d.species.find(s => s.key === sel) || d.species[0];
      html = speciesRow(sp);
      const adv = AdviceEngine.advise({ wind: d.cur.wind_speed_10m, score: d.score.score }, SpeciesEngine.get(sp.key));
      html += adviceBox(adv, sp);
    }
    $('#advice').innerHTML = html;
  }
  function speciesRow(s) {
    const col = ScoreEngine.color(s.prob);
    return '<div style="padding:8px 0"><div class="between"><span style="font-weight:700">' + s.emoji + ' ' + s.name + '</span><span style="font-weight:800;color:' + col + '">' + s.prob + '%</span></div><div class="prob"><i style="width:' + s.prob + '%;background:' + col + '"></i></div></div>';
  }
  function adviceBox(a, s) {
    return '<div class="tile" style="margin-top:10px"><div style="font-weight:700;margin-bottom:6px">🎣 ' + Util.esc(a.species) + ' plan</div>' +
      '<div style="font-size:13px;margin-bottom:6px">' + Util.esc(a.summary) + '</div>' +
      kv('Bait', Util.esc(a.baits.join(', '))) + kv('Rig', Util.esc(a.rig)) + kv('Tide', Util.esc(a.tideStage)) + kv('Best time', Util.esc(a.time)) + kv('Wind', Util.esc(a.wind)) +
      '<div class="muted" style="font-size:12px;margin-top:6px">' + Util.esc(a.tip) + '</div></div>';
  }
  function kv(k, v) { return '<div class="row" style="gap:8px;align-items:flex-start;font-size:13px;padding:2px 0"><span class="muted" style="width:64px;flex:0 0 auto">' + k + '</span><span>' + v + '</span></div>'; }
  function renderPlanner(d) {
    const days = d.daily.slice(0, 7);
    const best = days.reduce((a, b) => b.ds > a.ds ? b : a, days[0]), bi = days.indexOf(best);
    const lbl = bi === 0 ? 'today' : bi === 1 ? 'tomorrow' : best.date.toLocaleDateString('en-AU', { weekday: 'long' });
    $('#bestSession').innerHTML = '🎯 Best session: <span style="color:var(--text);font-weight:700;text-transform:capitalize">' + lbl + '</span> · score <span style="color:' + ScoreEngine.color(best.ds) + ';font-weight:800">' + best.ds + '</span> · ' + wmo(best.code)[0] + ' · wind ' + windDisp(best.wind) + ' ' + windUnit();
    $('#planRow').innerHTML = days.map((x, i) => {
      const dl = i === 0 ? 'Today' : i === 1 ? 'Tmrw' : x.date.toLocaleDateString('en-AU', { weekday: 'short' });
      const wknd = [0, 6].includes(x.date.getDay());
      return '<div class="planday' + (i === bi ? ' best' : '') + '"><div class="d"' + (wknd ? ' style="color:var(--sand)"' : '') + '>' + dl + (i === bi ? ' 🎯' : '') + '</div><div class="em">' + wmo(x.code)[1] + '</div><div class="s" style="color:' + ScoreEngine.color(x.ds) + '">' + x.ds + '</div><div class="d">' + windDisp(x.wind) + (AppState.units === 'kn' ? 'kn' : '') + '</div></div>';
    }).join('');
  }
  function renderSafety(d) {
    let box = $('#safetyBox');
    if (!box) { box = document.createElement('section'); box.id = 'safetyBox'; $('#scoreCard').after(box); }
    const w = d.score.warnings, danger = w.some(x => x[0] === 'danger'), warn = w.some(x => x[0] === 'warn');
    box.className = 'safety ' + (danger ? 'danger' : warn ? 'warn' : '');
    box.innerHTML = '<div class="row" style="font-weight:700;font-size:14px"><svg class="ic" style="color:' + (danger ? 'var(--bad)' : warn ? 'var(--warn)' : 'var(--good)') + '" viewBox="0 0 24 24"><path d="M12 9v4M12 17h.01M10.3 3.9L1.8 18a2 2 0 001.7 3h17a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z"/></svg>Safety &amp; conditions</div><ul>' +
      w.map(([k, t]) => '<li><i style="background:' + (k === 'danger' ? 'var(--bad)' : k === 'warn' ? 'var(--warn)' : 'var(--good)') + '"></i><span>' + Util.esc(t) + '</span></li>').join('') + '</ul>';
  }
  function renderSavedRecent() {
    const saved = FavoritesService.get();
    $('#savedBox').innerHTML = saved.length ? saved.map(s => '<button class="chip tap" data-go="' + s.lat + ',' + s.lon + '" data-name="' + Util.esc(s.name) + '" style="margin:0 6px 6px 0">⭐ ' + Util.esc(s.name) + ' <span class="muted" data-rm="' + s.lat + ',' + s.lon + '">×</span></button>').join('') : '<div class="muted" style="font-size:13px">Star a spot to pin it here.</div>';
    const rec = FavoritesService.recents();
    $('#recentBox').innerHTML = rec.length ? rec.map(s => '<button class="chip tap" data-go="' + s.lat + ',' + s.lon + '" data-name="' + Util.esc(s.name) + '">' + Util.esc(s.name) + '</button>').join('') : '<div class="muted" style="font-size:13px">Your recent searches show here.</div>';
    $$('#savedBox [data-go],#recentBox [data-go]').forEach(b => b.addEventListener('click', e => {
      if (e.target.dataset.rm) { const [la, lo] = e.target.dataset.rm.split(',').map(Number); FavoritesService.set(FavoritesService.get().filter(x => !(x.lat === la && x.lon === lo))); renderSavedRecent(); renderFav(); return; }
      const [la, lo] = b.dataset.go.split(',').map(Number); LocationService.load({ name: b.dataset.name, lat: la, lon: lo, source: 'favourite' }); window.scrollTo({ top: 0, behavior: 'smooth' });
    }));
    // header fav chips mirror saved
    $('#favChips').innerHTML = saved.map(s => '<button class="chip tap" data-go="' + s.lat + ',' + s.lon + '" data-name="' + Util.esc(s.name) + '">⭐ ' + Util.esc(s.name) + '</button>').join('');
    $$('#favChips [data-go]').forEach(b => b.addEventListener('click', () => { const [la, lo] = b.dataset.go.split(',').map(Number); LocationService.load({ name: b.dataset.name, lat: la, lon: lo, source: 'favourite' }); window.scrollTo({ top: 0, behavior: 'smooth' }); }));
  }
  // catch log
  function renderLog() {
    const log = CatchLogService.get();
    const total = log.length, species = new Set(log.map(c => c.species)).size; let pb = null; log.forEach(c => { if (c.length && (!pb || c.length > pb.length)) pb = c; });
    $('#logStats').innerHTML = [['Catches', total], ['Species', species], ['PB', pb ? (pb.length + 'cm') : '—']].map(([k, v]) => '<div class="tile" style="text-align:center"><div class="k">' + k + '</div><div class="v" style="font-size:18px">' + Util.esc(String(v)) + '</div></div>').join('');
    $('#logList').innerHTML = log.length ? log.slice().reverse().map(c => {
      const sp = SpeciesEngine.get((c.species || '').toLowerCase());
      return '<div class="tideRow" style="padding:8px 0;border-bottom:1px solid var(--line)"><span style="font-size:20px">' + (sp ? sp.emoji : '🐟') + '</span><div style="flex:1"><div style="font-weight:700">' + Util.esc(c.species) + (c.length ? ' <span style="color:var(--aqua)">' + c.length + 'cm</span>' : '') + '</div><div class="muted" style="font-size:12px">' + Util.esc(c.spot || '') + ' · ' + new Date(c.ts).toLocaleDateString('en-AU', { day: 'numeric', month: 'short' }) + (c.bait ? ' · ' + Util.esc(c.bait) : '') + '</div>' + (c.notes ? '<div style="font-size:12px;margin-top:2px">' + Util.esc(c.notes) + '</div>' : '') + '</div><button class="muted" data-del="' + c.id + '" style="font-size:12px">Delete</button></div>';
    }).join('') : '<div class="muted" style="font-size:13px;text-align:center;padding:14px">No catches yet. Tap <b>+ Log a catch</b> to start your logbook (saved on this device only).</div>';
    $$('#logList [data-del]').forEach(b => b.addEventListener('click', () => { CatchLogService.del(b.dataset.del); renderLog(); Util.toast('Catch deleted'); }));
  }
  function openCatchSheet() {
    const d = AppState.data, opts = SpeciesEngine.DB.map(s => '<option>' + s.name + '</option>').join('');
    const snap = d ? ('Auto-saved: score ' + d.score.score + ', wind ' + windDisp(d.cur.wind_speed_10m) + ' ' + windUnit() + ', ' + d.moon.phase) : 'No live conditions yet.';
    openSheet('<h2 style="font-size:18px">Log a catch</h2><div class="muted" style="font-size:12px;margin:4px 0 6px">' + Util.esc(snap) + '</div>' +
      '<label>Species</label><select id="cSp">' + opts + '</select>' +
      '<div class="grid2"><div><label>Length (cm)</label><input id="cLen" type="number" inputmode="numeric" placeholder="38"></div><div><label>Bait / lure</label><input id="cBait" placeholder="live prawn"></div></div>' +
      '<label>Spot</label><input id="cSpot" value="' + (AppState.loc ? Util.esc(AppState.loc.name) : '') + '">' +
      '<label>Notes</label><textarea id="cNotes" rows="2" placeholder="tide, technique, who with…"></textarea>' +
      '<label style="display:flex;align-items:center;gap:8px;margin-top:10px;font-size:13px;color:var(--text)"><input type="checkbox" id="cBlank" style="width:auto;flex:0 0 auto"> No fish — log the conditions only (helps tune your score)</label>' +
      '<button id="cSave" class="btn primary full" style="margin-top:14px">Save to logbook</button>');
    $('#cSave').addEventListener('click', () => {
      const blank = !!$('#cBlank').checked;
      const c = { id: 'c' + Date.now(), ts: Date.now(), species: blank ? 'Blank session' : $('#cSp').value, length: blank ? null : (parseFloat($('#cLen').value) || null), bait: $('#cBait').value.trim(), spot: $('#cSpot').value.trim(), notes: $('#cNotes').value.trim(), blank };
      if (d) {
        c.score = d.score.score; c.moon = d.moon.phase;
        c.cond = CalibrationService.vectorFrom({ tideDir: d.tide.dir, tideState: d.tide.state, wind: d.cur.wind_speed_10m, isDawnDusk: d.score.isDawnDusk, isDay: d.cur.is_day, moonPhase: d.moon.phase, pressTrend: d.score.pressTrend });
      }
      CatchLogService.add(c); closeSheet(); renderLog();
      Util.toast(blank ? 'Conditions logged' : '🎣 Catch logged!');
    });
  }
  // sheet (back-button aware: opening pushes a history entry, back/close pops it)
  function sheetOpen() { return $('#sheetWrap').classList.contains('open'); }
  function openSheet(html) {
    const wasClosed = !sheetOpen();
    $('#sheet').innerHTML = '<div style="width:40px;height:4px;border-radius:99px;background:var(--line);margin:0 auto 10px"></div>' + html;
    $('#sheet').scrollTop = 0; $('#sheetWrap').classList.add('open');
    if (wasClosed) { try { history.pushState({ sheet: true }, ''); } catch (_) { } }
  }
  function closeSheet() { if (!sheetOpen()) return; if (history.state && history.state.sheet) { history.back(); } else { $('#sheetWrap').classList.remove('open'); } }
  function hideSheet() { $('#sheetWrap').classList.remove('open'); } // popstate-driven, no history change
  function seasonName(m) { if ([12, 1, 2].includes(m)) return 'Summer'; if ([3, 4, 5].includes(m)) return 'Autumn'; if ([6, 7, 8].includes(m)) return 'Winter'; return 'Spring'; }
  function windDisp(kmh) { return AppState.units === 'kn' ? Util.round(kmh / 1.852) : Util.round(kmh); }
  function windUnit() { return AppState.units === 'kn' ? 'kn' : 'km/h'; }
  function sameDay(a, b) { return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate(); }
  return { render, setLocName, loadingHero, flagStale, renderFav, renderSavedRecent, renderLog, openCatchSheet, openSheet, closeSheet, hideSheet, sheetOpen };
})();

/* ---------------- DebugService panel (?debug=true) ---------------- */
function openDebugPanel() {
  const d = AppState.data, a = DebugService.d.attempts;
  const row = (k, v) => '<div class="kv"><span>' + Util.esc(k) + '</span><span>' + Util.esc(v == null ? '—' : String(v)) + '</span></div>';
  let h = '<div id="debug"><h2 style="font-size:16px">🐞 Debug</h2>';
  h += row('SW version', DebugService.d.swVersion);
  h += row('Online', navigator.onLine);
  if (AppState.loc) { h += row('Location', AppState.loc.name); h += row('Source', AppState.loc.source); h += row('Lat,Lon', Util.round(AppState.loc.lat, 4) + ', ' + Util.round(AppState.loc.lon, 4)); }
  if (a.weather) { h += row('Weather url', a.weather.url); h += row('Weather attempted', a.weather.attempted); h += row('Weather status', a.weather.status); h += row('Weather ms', a.weather.ms); h += row('Weather provider', a.weather.provider); }
  if (a.tide) { h += row('Tide url', a.tide.url); h += row('Tide attempted', a.tide.attempted); h += row('Tide status', a.tide.status); h += row('Tide ms', a.tide.ms); if (a.tide.error) h += row('Tide error', a.tide.error); }
  if (a.tideResult) { h += row('Tide source used', a.tideResult.source); h += row('Tide fallbackReason', a.tideResult.fallbackReason); h += row('Tide cacheKey', a.tideResult.cacheKey); h += row('Tide cacheHit', a.tideResult.cacheHit); }
  if (d) { h += row('Score', d.score.score + ' (' + d.score.label + ')'); h += row('Confidence', d.score.confidence + ' · ' + d.score.confWhy); h += row('Solunar', d.score.inputs.solScore); h += row('Wind in', d.score.inputs.wind); h += row('Pressure trend', d.score.pressTrend); h += row('Dawn/Dusk', d.score.isDawnDusk); h += row('Weather known', d.score.inputs.weatherKnown); h += row('Tide real', d.tide.real); h += row('Data age', Util.ago(d.fetchedAt)); h += row('loadSeq', AppState.loadSeq); h += row('Stale-guard', 'active (seq compared each phase)'); }
  h += '</div><button class="btn full" style="margin-top:14px" onclick="UIServiceClose()">Close</button>';
  UIService.openSheet(h);
}
function UIServiceClose() { UIService.closeSheet(); }

/* ---------------- Settings (theme · units · connection ping) ---------------- */
function openSettings() {
  const t = ThemeService.get(), u = AppState.units;
  const seg = (v, l) => '<button data-theme="' + v + '" class="seg' + (t === v ? ' on' : '') + '">' + l + '</button>';
  const useg = (v, l) => '<button data-unit="' + v + '" class="seg' + (u === v ? ' on' : '') + '">' + l + '</button>';
  const cal = CalibrationService.on();
  const cseg = (v, l) => '<button data-calib="' + v + '" class="seg' + (cal === v ? ' on' : '') + '">' + l + '</button>';
  UIService.openSheet(
    '<h2 style="font-size:18px;margin-bottom:4px">Settings</h2>' +
    '<label>Appearance</label><div class="segrow">' + seg('dark', '🌙 Dark') + seg('light', '☀️ Light') + seg('fun', '🎉 Fun') + '</div>' +
    '<label>Wind units</label><div class="segrow">' + useg('kmh', 'km/h') + useg('kn', 'Knots') + '</div>' +
    '<label>Learn from my catches (beta)</label><div class="segrow">' + cseg(true, '🧠 On') + cseg(false, 'Off') + '</div>' +
    '<div class="muted" style="font-size:11px;margin-top:4px">Personal, on-device tuning of your SendIt Score from your catch log — bounded ±12 pts, needs 8+ catches with conditions (you have ' + CalibrationService.counts().n + '). Also log “no fish” sessions to teach it. Nothing leaves your device.</div>' +
    '<div class="between" style="margin-top:16px"><div><div style="font-weight:700">Connection test</div><div class="muted" style="font-size:12px">Ping each free data source</div></div><button id="pingBtn" class="btn tap">🔌 Ping</button></div>' +
    '<div id="pingOut" style="margin-top:8px"></div>' +
    '<button id="clearLogBtn" class="btn full tap" style="margin-top:16px;color:var(--bad)">Clear catch log</button>' +
    '<button id="setDone" class="btn primary full tap" style="margin-top:10px">Done</button>' +
    '<div class="muted" style="font-size:11px;margin-top:14px">SendIt Fishing — your catch log, spots & settings stay on this device. Weather/tide from Open-Meteo + MET Norway (free, no key); moon & solunar computed on-device.</div>'
  );
  $$('#sheet [data-theme]').forEach(b => b.addEventListener('click', () => { ThemeService.set(b.dataset.theme); openSettings(); Util.toast('Theme: ' + b.dataset.theme); }));
  $$('#sheet [data-unit]').forEach(b => b.addEventListener('click', () => { AppState.units = b.dataset.unit; CacheService.set('units', AppState.units); if (AppState.data) UIService.render(AppState.data, AppState.data.score.stale); openSettings(); }));
  $$('#sheet [data-calib]').forEach(b => b.addEventListener('click', () => { CalibrationService.setOn(b.dataset.calib === 'true'); if (AppState.data) UIService.render(AppState.data, AppState.data.score.stale); openSettings(); Util.toast('Catch-log tuning ' + (b.dataset.calib === 'true' ? 'on' : 'off')); }));
  $('#setDone').addEventListener('click', UIService.closeSheet);
  $('#clearLogBtn').addEventListener('click', () => { if (confirm('Delete all logged catches? This cannot be undone.')) { CatchLogService.set([]); UIService.renderLog(); UIService.closeSheet(); Util.toast('Catch log cleared'); } });
  $('#pingBtn').addEventListener('click', async () => {
    const out = $('#pingOut'); out.innerHTML = '<span class="muted">Pinging 5 sources…</span>';
    const loc = AppState.loc || { lat: -33.87, lon: 151.21 };
    const res = await DiagnosticsService.ping(loc.lat, loc.lon);
    out.innerHTML = res.map(r => '<div class="pingrow"><span><span style="color:' + (r.ok ? 'var(--good)' : 'var(--bad)') + ';font-weight:800">' + (r.ok ? '✓' : '✕') + '</span> ' + Util.esc(r.name) + '</span><span class="muted">' + (r.ok ? r.ms + ' ms' : r.code) + '</span></div>').join('') +
      '<div class="faint" style="font-size:11px;margin-top:6px">✕ = blocked/unreachable (firewall or offline). Moon, solunar &amp; the tide engine still work fully offline.</div>';
  });
}

/* ---------------- search wiring ---------------- */
let searchTimer = null, searchCtrl = null;
function bindSearch() {
  const inp = $('#search'), sug = $('#suggest'), clr = $('#searchClear');
  inp.addEventListener('input', () => {
    const q = inp.value.trim(); clr.classList.toggle('hidden', !q); clearTimeout(searchTimer);
    if (q.length < 2) { sug.classList.add('hidden'); return; }
    searchTimer = setTimeout(async () => {
      if (searchCtrl) searchCtrl.abort(); searchCtrl = new AbortController();
      const res = await GeocodingService.search(q, searchCtrl.signal);
      if (!res.length) { sug.innerHTML = '<div style="padding:11px 12px" class="muted">No matches in Australia</div>'; sug.classList.remove('hidden'); return; }
      sug.innerHTML = res.map((r, i) => '<button data-i="' + i + '"><svg class="ic muted" viewBox="0 0 24 24"><path d="M12 21s-7-5.5-7-11a7 7 0 0114 0c0 5.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg><span>' + Util.esc(r.name) + '</span></button>').join('');
      sug.classList.remove('hidden');
      $$('#suggest button').forEach(b => b.addEventListener('click', () => { const r = res[+b.dataset.i]; inp.value = r.name; sug.classList.add('hidden'); clr.classList.add('hidden'); LocationService.load(Object.assign({}, r, { source: 'search' })); window.scrollTo({ top: 0, behavior: 'smooth' }); }));
    }, 280);
  });
  clr.addEventListener('click', () => { inp.value = ''; clr.classList.add('hidden'); sug.classList.add('hidden'); });
  document.addEventListener('click', e => { if (!e.target.closest('#suggest') && !e.target.closest('.searchbar')) sug.classList.add('hidden'); });
}

/* ---------------- ServiceWorker registration + PWA ---------------- */
function registerSW() { if ('serviceWorker' in navigator) window.addEventListener('load', () => navigator.serviceWorker.register('sw.js').catch(() => { })); }

/* ---------------- boot ---------------- */
function bindUI() {
  $('#gpsBtn').addEventListener('click', () => LocationService.gps());
  $('#favBtn').addEventListener('click', () => { if (!AppState.loc) return; FavoritesService.toggle(AppState.loc); UIService.renderFav(); UIService.renderSavedRecent(); });
  $('#refreshBtn').addEventListener('click', () => { if (AppState.loc) LocationService.load(AppState.loc); });
  $('#locBtn').addEventListener('click', () => $('#search').focus());
  $('#addCatch').addEventListener('click', () => UIService.openCatchSheet());
  $('#setBtn').addEventListener('click', () => openSettings());
  $('#sheetBg').addEventListener('click', () => UIService.closeSheet());
  // hardware / browser Back closes an open sheet instead of leaving the app
  window.addEventListener('popstate', () => { if (UIService.sheetOpen()) UIService.hideSheet(); });
  // long-press score for debug
  const card = $('#scoreCard'); let lp; const start = () => { lp = setTimeout(openDebugPanel, 650); }, cancel = () => clearTimeout(lp);
  card.addEventListener('touchstart', start, { passive: true }); card.addEventListener('touchend', cancel); card.addEventListener('touchmove', cancel);
  card.addEventListener('mousedown', start); card.addEventListener('mouseup', cancel); card.addEventListener('mouseleave', cancel);
  window.addEventListener('online', () => { AppState.online = true; if (AppState.loc) LocationService.load(AppState.loc); });
  window.addEventListener('offline', () => { AppState.online = false; });
  let rz; window.addEventListener('resize', () => { clearTimeout(rz); rz = setTimeout(() => { if (AppState.data) UIService.render(AppState.data, AppState.data.score.stale); }, 200); });
}
function boot() {
  ThemeService.apply(ThemeService.get());
  const u = CacheService.get('units', null); if (u === 'kn' || u === 'kmh') AppState.units = u;
  bindSearch(); bindUI(); registerSW();
  UIService.renderSavedRecent(); UIService.renderLog(); UIService.renderFav();
  const last = LocationService.getLast();
  LocationService.load(last && last.lat ? last : LocationService.DEFAULT);
  if (AppState.debug) setTimeout(openDebugPanel, 1200);
  // refresh every 15 min on the active location
  setInterval(() => { if (AppState.loc && document.visibilityState === 'visible') LocationService.load(AppState.loc); }, 15 * 60000);
}
document.addEventListener('DOMContentLoaded', boot);
</script>
</body>
</html>
